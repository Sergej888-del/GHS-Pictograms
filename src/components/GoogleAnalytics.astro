---
// Google Analytics 4 + Consent Mode v2 + cookie consent banner.
// Single source of truth — included in Layout.astro AND in standalone pages.
//
// Behaviour:
//   - analytics_storage defaults to 'denied' BEFORE GA4 loads (Consent Mode v2),
//     so no analytics cookies are set until the visitor accepts.
//   - A previously stored choice is honoured immediately on load.
//   - A bottom banner (injected on DOMContentLoaded) lets the visitor Accept/Decline.
//   - window.openCookieSettings() re-opens the banner (used by the footer link).
// Keep the scripts `is:inline` so Astro does not bundle/transform them.
---
<!-- GA4 + Consent Mode v2 -->
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}

  // Default: deny analytics until the visitor consents (must run before GA4 loads).
  gtag('consent', 'default', {
    ad_storage: 'denied',
    ad_user_data: 'denied',
    ad_personalization: 'denied',
    analytics_storage: 'denied'
  });

  // Honour a stored choice immediately so returning visitors are tracked from the first hit.
  try {
    if (localStorage.getItem('ga-consent') === 'granted') {
      gtag('consent', 'update', { analytics_storage: 'granted' });
    }
  } catch (e) {}
</script>
<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-7T76LL8ZF3"></script>
<script is:inline>
  gtag('js', new Date());
  gtag('config', 'G-7T76LL8ZF3');

  // ---- Cookie consent banner -------------------------------------------------
  (function () {
    var KEY = 'ga-consent';

    function grant() {
      try { localStorage.setItem(KEY, 'granted'); } catch (e) {}
      gtag('consent', 'update', { analytics_storage: 'granted' });
    }
    function deny() {
      try { localStorage.setItem(KEY, 'denied'); } catch (e) {}
      gtag('consent', 'update', { analytics_storage: 'denied' });
    }
    function removeBanner() {
      var b = document.getElementById('cookie-consent-banner');
      if (b && b.parentNode) b.parentNode.removeChild(b);
    }

    function buildBanner() {
      if (document.getElementById('cookie-consent-banner')) return;

      var bar = document.createElement('div');
      bar.id = 'cookie-consent-banner';
      bar.setAttribute('role', 'dialog');
      bar.setAttribute('aria-label', 'Cookie consent');
      bar.style.cssText = 'position:fixed;left:0;right:0;bottom:0;z-index:9999;background:#062A78;color:#fff;padding:14px 16px;font-family:Inter,system-ui,sans-serif;font-size:14px;line-height:1.5;box-shadow:0 -2px 12px rgba(0,0,0,.25);';

      var inner = document.createElement('div');
      inner.style.cssText = 'max-width:1100px;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;gap:12px 20px;justify-content:space-between;';

      var text = document.createElement('p');
      text.style.cssText = 'margin:0;flex:1 1 320px;';
      text.innerHTML = 'We use cookies for analytics (Google Analytics) to understand site usage. Analytics cookies are set only with your consent. See our <a href="/privacy/" style="color:#bfdbfe;text-decoration:underline;">Privacy Policy</a>.';

      var btns = document.createElement('div');
      btns.style.cssText = 'display:flex;gap:10px;flex:0 0 auto;';

      var decline = document.createElement('button');
      decline.type = 'button';
      decline.textContent = 'Decline';
      decline.style.cssText = 'cursor:pointer;padding:8px 16px;border-radius:6px;border:1px solid rgba(255,255,255,.6);background:transparent;color:#fff;font:inherit;font-weight:600;';
      decline.onclick = function () { deny(); removeBanner(); };

      var accept = document.createElement('button');
      accept.type = 'button';
      accept.textContent = 'Accept';
      accept.style.cssText = 'cursor:pointer;padding:8px 16px;border-radius:6px;border:1px solid #fff;background:#fff;color:#062A78;font:inherit;font-weight:600;';
      accept.onclick = function () { grant(); removeBanner(); };

      btns.appendChild(decline);
      btns.appendChild(accept);
      inner.appendChild(text);
      inner.appendChild(btns);
      bar.appendChild(inner);
      document.body.appendChild(bar);
    }

    function maybeShow() {
      var choice = null;
      try { choice = localStorage.getItem(KEY); } catch (e) {}
      if (!choice) buildBanner();
    }

    // Footer "Cookie settings" link re-opens the banner.
    window.openCookieSettings = function () {
      try { localStorage.removeItem(KEY); } catch (e) {}
      removeBanner();
      buildBanner();
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', maybeShow);
    } else {
      maybeShow();
    }
  })();
</script>
