---
// Базовый layout для всех страниц ghspictograms.com
import '../styles/global.css'

interface Props {
  title: string
  description?: string
  canonical?: string
}

const {
  title,
  description = 'GHS pictograms, label builder and visual chemical safety tools for design, logistics and compliance.',
  canonical
} = Astro.props

const siteUrl = 'https://ghspictograms.com'
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title} | GHS Pictograms</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | GHS Pictograms`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <slot name="head" />
    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-1Y5MKV5XMK"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-1Y5MKV5XMK');
    </script>
  </head>
  <body class="bg-white text-gray-900 font-sans antialiased">
    <header class="bg-[#062A78] sticky top-0 z-50">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 font-bold text-xl text-white">
          GHS Pictograms
        </a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="bg-[#062A78] mt-24 py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-sm text-blue-200 text-center">
        <p class="text-white font-semibold mb-2">GHS Pictograms</p>
        <p>Visual GHS tools for labels, logistics and compliance.</p>
        <p class="mt-4 text-blue-300">© 2026 GHS Pictograms</p>
      </div>
    </footer>
  </body>
</html>
