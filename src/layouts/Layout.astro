---
// Базовый layout для всех страниц ghspictograms.com
import '../styles/global.css'

interface Props {
  title: string
  description?: string
  canonical?: string
  /** Если true, в <title> используется только `title` без суффикса «| GHS Pictograms» */
  titleIsComplete?: boolean
}

const {
  title,
  description = 'GHS pictograms, label builder and visual chemical safety tools for design, logistics and compliance.',
  canonical,
  titleIsComplete = false,
} = Astro.props

const pageTitle = titleIsComplete ? title : `${title} | GHS Pictograms`

const siteUrl = 'https://ghspictograms.com'
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`

/** Текущий сайт в экосистеме — всегда ghspictograms в этом layout */
const ecosystem = [
  { label: 'GHS Symbols', href: 'https://ghssymbols.com', id: 'symbols' as const },
  { label: 'GHS Pictograms', href: 'https://ghspictograms.com', id: 'pictograms' as const },
  { label: 'GHS Labels', href: 'https://ghslabels.com', id: 'labels' as const },
]
const activeId = 'pictograms'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <!-- Google Analytics 4 -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-7T76LL8ZF3"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-7T76LL8ZF3');
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <title>{pageTitle}</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <slot name="head" />
  </head>
  <body class="bg-white text-gray-900 font-sans antialiased">
    <div style="background:#1e40af;color:white;text-align:center;padding:6px 16px;font-size:12px;font-weight:600;letter-spacing:0.05em;">
      BETA — This tool is in active development. Data is for reference only.
    </div>
    <header class="bg-[#062A78] sticky top-0 z-50">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-4" aria-label="Main">
        <a href="/" class="flex items-center gap-2 font-bold text-xl text-white shrink-0">
          GHS Pictograms
        </a>

        <ul class="hidden md:flex items-center gap-1 lg:gap-2 text-sm font-medium">
          {ecosystem.map(({ label, href, id }) => (
            <li>
              <a
                href={href}
                class:list={[
                  'inline-block rounded-md px-3 py-1.5 transition-colors',
                  id === activeId
                    ? 'bg-white text-[#062A78] font-semibold shadow-sm'
                    : 'text-white hover:bg-white/10',
                ]}
              >
                {label}
              </a>
            </li>
          ))}
          <li class="mx-1 h-6 w-px bg-white/20" aria-hidden="true"></li>
          <li>
            <a href="/blog/" class="inline-block rounded-md px-3 py-1.5 transition-colors text-white hover:bg-white/10">
              Blog
            </a>
          </li>
          <li>
            <a href="/faq/" class="inline-block rounded-md px-3 py-1.5 transition-colors text-white hover:bg-white/10">
              FAQ
            </a>
          </li>
        </ul>

        <button
          type="button"
          id="layout-mobile-menu-btn"
          class="md:hidden text-white p-2 hover:bg-white/10 rounded-lg transition-colors"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="layout-mobile-menu"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </nav>

      <!-- Мобильное меню: полная ширина под шапкой -->
      <div id="layout-mobile-menu" class="hidden md:hidden border-t border-white/20 bg-[#062A78] px-4 sm:px-6 lg:px-8 py-4">
        <ul class="flex flex-col gap-1 text-sm font-medium max-w-7xl mx-auto">
          {ecosystem.map(({ label, href, id }) => (
            <li>
              <a
                href={href}
                class:list={[
                  'block py-3 px-2 rounded-md transition-colors',
                  id === activeId
                    ? 'bg-white text-[#062A78] font-semibold'
                    : 'text-white/80 hover:text-white',
                ]}
              >
                {label}
              </a>
            </li>
          ))}
          <li class="my-2 border-t border-white/20" aria-hidden="true"></li>
          <li>
            <a href="/blog/" class="block py-3 px-2 text-white/80 hover:text-white transition-colors rounded-md">
              Blog
            </a>
          </li>
          <li>
            <a href="/faq/" class="block py-3 px-2 text-white/80 hover:text-white transition-colors rounded-md">
              FAQ
            </a>
          </li>
        </ul>
      </div>
    </header>

    <script is:inline>
      document.getElementById('layout-mobile-menu-btn')?.addEventListener('click', function () {
        const menu = document.getElementById('layout-mobile-menu')
        menu?.classList.toggle('hidden')
        const open = menu && !menu.classList.contains('hidden')
        const btn = document.getElementById('layout-mobile-menu-btn')
        btn?.setAttribute('aria-expanded', open ? 'true' : 'false')
      })
    </script>

    <div class="bg-blue-950 text-blue-200 text-sm py-1.5">
      <div class="max-w-7xl mx-auto px-4 flex items-center justify-center gap-6 flex-wrap">
        <span class="text-blue-400 font-medium">GHS Ecosystem:</span>
        <a href="https://ghssymbols.com" class="hover:text-white transition-colors flex items-center gap-1">
          GHS Symbols <span class="text-blue-500">→ Hazard Classification & ATE Calculator</span>
        </a>
        <span class="text-blue-300">▶ You are on GHS Pictograms</span>
      </div>
    </div>

    <main>
      <slot />
    </main>

    <footer class="bg-[#062A78] mt-24 py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-sm text-blue-200 text-center">
        <p class="text-white font-semibold mb-2">GHS Pictograms</p>
        <p>Visual GHS tools for labels, logistics and compliance.</p>
        <p class="mt-4 text-blue-300">© 2026 GHS Pictograms</p>
      </div>
    </footer>
  </body>
</html>
