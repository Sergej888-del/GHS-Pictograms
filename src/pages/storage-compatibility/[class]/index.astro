---
// Storage-class category page — /storage-compatibility/<slug>/
// One page per storage class (getStaticPaths over STORAGE_CLASSES). Data-driven:
//   * hero + count            (get_class_substances total)
//   * compatibility-at-a-glance: never / keep separate / compatible pills,
//     each -> the other class's page (interlink graph)
//   * substances in this class: ALL baked into HTML, first 50 shown + the rest
//     behind a "Show all N" toggle; each -> the tool's ?substance= deep-link
//   * optional editorial prose + FAQ from the `storage-classes` content collection
//   * CollectionPage + ItemList (+ FAQPage when prose has faq) JSON-LD
// Prose is OPTIONAL (P4). Without an entry the page renders data-only; such
// pages should not be linked/sitemapped until prose lands (publication control
// handled outside this file — see P2 notes).
import Layout from '../../../layouts/Layout.astro'
import { STORAGE_CLASSES, shortForCode, urlForCode, familyStyleForCode, HERO_BG, HERO_DOTS } from '../../../lib/storageClasses'
import { supabase } from '../../../lib/supabase'
import { getCollection, render } from 'astro:content'

const SITE = 'https://ghspictograms.com'
const TOOL = '/tools/chemical-storage-compatibility/'

export async function getStaticPaths() {
  // Top-level module imports (STORAGE_CLASSES, supabase) ARE visible here; only
  // `---` consts are not. High p_limit => bake the full class list into the HTML.
  const pages = await Promise.all(
    STORAGE_CLASSES.map(async (cls) => {
      const [subsRes, compatRes] = await Promise.all([
        supabase.rpc('get_class_substances', { p_sc_code: cls.code, p_limit: 5000 }),
        supabase.rpc('get_class_compatibility', { p_sc_code: cls.code }),
      ])
      const subs = subsRes.data ?? { sc_code: cls.code, total: 0, items: [] }
      const compat = compatRes.data?.compat ?? []
      return { params: { class: cls.slug }, props: { cls, subs, compat } }
    }),
  )
  return pages
}

interface SubItem { cas: string; name: string; signal_word: string | null }
interface CompatItem { class: string; name: string; status: 'prohibited' | 'separate' | 'compatible' }

const { cls, subs, compat } = Astro.props as {
  cls: { code: string; slug: string; short: string }
  subs: { sc_code: string; total: number; items: SubItem[] }
  compat: CompatItem[]
}

// Optional editorial prose. Collection NAME is the config key `storageClasses`;
// content FILES live in src/content/storage-classes/ (filename === class slug).
const entries = await getCollection('storageClasses').catch(() => [])
const entry = entries.find((e) => e.id === cls.slug && !e.data.draft) ?? null
const Content = entry ? (await render(entry)).Content : null

const never = compat.filter((c) => c.status === 'prohibited')
const separate = compat.filter((c) => c.status === 'separate')
const compatible = compat.filter((c) => c.status === 'compatible')

const total = subs.total ?? 0
const items = subs.items ?? []
const COLLAPSE_AT = 50 // first 50 shown; the rest collapsed behind a toggle

// SEO — prose frontmatter wins; sensible data-driven fallback otherwise.
const title = entry?.data.title ?? `${cls.short} — storage, segregation & compatibility`
const description =
  entry?.data.description ??
  `What ${cls.short.toLowerCase()} can and can't be stored with — segregation by GHS hazard class, chemical reactivity, and ADR transport. ${total} substances in our database.`
const canonical = `${SITE}/storage-compatibility/${cls.slug}/`

// Structured data.
const jsonLd: Record<string, unknown>[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: title,
    description,
    url: canonical,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: `${cls.short} — substances`,
    numberOfItems: total,
    itemListElement: items.slice(0, 100).map((s, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: s.name,
      url: `${SITE}${TOOL}?substance=${encodeURIComponent(s.cas)}`,
    })),
  },
]
if (entry?.data.faq?.length) {
  jsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: entry.data.faq.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  })
}

const pillBase = 'inline-flex items-center rounded-full border px-3 py-1 text-sm transition-all hover:shadow-sm'
const fam = familyStyleForCode(cls.code)
---

<Layout title={title} description={description} canonical={canonical}>
  <!-- Data-only pages (no prose entry) stay out of the index until P4 prose lands -->
  {!entry && <meta name="robots" content="noindex,follow" slot="head" />}

  <!-- HERO: textured gradient + dot overlay (shared with hub) -->
  <section class="relative overflow-hidden text-white" style={`background:${HERO_BG};`}>
    <div class="absolute inset-0 opacity-40" style={`background-image:${HERO_DOTS};background-size:22px 22px;`} aria-hidden="true"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <nav class="text-sm text-slate-300 mb-6" aria-label="Breadcrumb">
        <a href="/storage-compatibility/" class="hover:text-white transition-colors">Storage compatibility</a>
        <span class="mx-1 text-slate-500">/</span>
        <span class="text-slate-200">{cls.short}</span>
      </nav>
      <div class="flex items-start gap-4">
        <div class="hidden sm:flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-teal-500 shadow-lg shadow-teal-900/40">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="7" height="7" rx="1.5"></rect>
            <rect x="14" y="3" width="7" height="7" rx="1.5"></rect>
            <rect x="3" y="14" width="7" height="7" rx="1.5"></rect>
            <rect x="14" y="14" width="7" height="7" rx="1.5"></rect>
          </svg>
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-teal-300">{fam.label} · storage class</p>
          <h1 class="mt-1.5 text-4xl sm:text-5xl font-extrabold tracking-tight leading-[1.05]" style="font-family:'Space Grotesk',sans-serif;">
            {title}
          </h1>
          <p class="mt-4 text-lg text-slate-200 max-w-3xl leading-relaxed">
            {entry?.data.intro ??
              `Storage segregation, incompatibilities, and the ${total} substances in this class in our database.`}
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-10">
    <!-- COMPATIBILITY AT A GLANCE -->
    <section>
      <h2 class="text-xl font-bold text-gray-900" style="font-family:'Space Grotesk',sans-serif;">
        What {cls.short.toLowerCase()} can be stored with
      </h2>
      <p class="mt-1 text-sm text-gray-500">
        Class-level segregation. Tap a class to see its own guidance.
      </p>

      {never.length > 0 && (
        <div class="mt-4">
          <h3 class="flex items-center gap-1.5 text-sm font-semibold text-red-700">
            <span aria-hidden="true">⛔</span> Never store with
          </h3>
          <div class="mt-2 flex flex-wrap gap-2">
            {never.map((c) => (
              <a href={urlForCode(c.class)} class={`${pillBase} border-red-200 bg-red-50 text-red-700 hover:bg-red-100`}>
                {shortForCode(c.class)}
              </a>
            ))}
          </div>
        </div>
      )}

      {separate.length > 0 && (
        <div class="mt-4">
          <h3 class="flex items-center gap-1.5 text-sm font-semibold text-amber-700">
            <span aria-hidden="true">↔</span> Keep separate
          </h3>
          <div class="mt-2 flex flex-wrap gap-2">
            {separate.map((c) => (
              <a href={urlForCode(c.class)} class={`${pillBase} border-amber-200 bg-amber-50 text-amber-800 hover:bg-amber-100`}>
                {shortForCode(c.class)}
              </a>
            ))}
          </div>
        </div>
      )}

      {compatible.length > 0 && (
        <div class="mt-4">
          <h3 class="flex items-center gap-1.5 text-sm font-semibold text-green-700">
            <span aria-hidden="true">✓</span> Generally compatible
          </h3>
          <div class="mt-2 flex flex-wrap gap-2">
            {compatible.map((c) => (
              <a href={urlForCode(c.class)} class={`${pillBase} border-green-200 bg-green-50 text-green-700 hover:bg-green-100`}>
                {shortForCode(c.class)}
              </a>
            ))}
          </div>
        </div>
      )}
    </section>

    <!-- EDITORIAL PROSE (optional, P4) -->
    {Content && (
      <section class="prose prose-slate max-w-none prose-headings:font-[Space_Grotesk]">
        <Content />
      </section>
    )}

    <!-- SUBSTANCES IN THIS CLASS -->
    <section>
      <h2 class="text-xl font-bold text-gray-900" style="font-family:'Space Grotesk',sans-serif;">
        {cls.short} in our database
      </h2>
      <p class="mt-1 text-sm text-gray-500">
        {total === 0
          ? 'No substances currently classified into this class.'
          : `${total} substance${total === 1 ? '' : 's'}. Open any for its full storage verdict.`}
      </p>

      {items.length > 0 && (
        <ul id="ss-list" class="ss-list ss-collapsed mt-3 grid grid-cols-1 sm:grid-cols-2 gap-2">
          {items.map((s, i) => (
            <li class={i >= COLLAPSE_AT ? 'ss-extra' : undefined}>
              <a
                href={`${TOOL}?substance=${encodeURIComponent(s.cas)}`}
                class="flex items-baseline justify-between gap-3 rounded-lg border border-gray-200 bg-white px-3 py-2.5 hover:border-teal-300 hover:bg-teal-50/50 hover:shadow-sm transition-all"
              >
                <span class="min-w-0">
                  <span class="block text-sm font-medium text-gray-900 truncate">{s.name}</span>
                  <span class="block text-xs text-gray-500 font-mono">{s.cas}</span>
                </span>
                {s.signal_word && (
                  <span
                    class={`shrink-0 rounded px-1.5 py-0.5 text-[11px] font-semibold ${
                      s.signal_word === 'Danger'
                        ? 'bg-red-50 text-red-700'
                        : 'bg-amber-50 text-amber-800'
                    }`}
                  >
                    {s.signal_word}
                  </span>
                )}
              </a>
            </li>
          ))}
        </ul>
      )}

      {total > COLLAPSE_AT && (
        <button
          id="ss-toggle"
          type="button"
          data-all={`Show all ${total} substances ↓`}
          class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-teal-700 hover:underline"
        >
          Show all {total} substances ↓
        </button>
      )}
    </section>

    <!-- FAQ (optional, P4) -->
    {entry?.data.faq && entry.data.faq.length > 0 && (
      <section>
        <h2 class="text-xl font-bold text-gray-900" style="font-family:'Space Grotesk',sans-serif;">
          Frequently asked questions
        </h2>
        <div class="mt-4 space-y-4">
          {entry.data.faq.map((f) => (
            <div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
              <p class="text-sm font-semibold text-gray-900">{f.q}</p>
              <p class="mt-1 text-sm text-gray-600">{f.a}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- DISCLAIMER + BACK TO TOOL -->
    <section class="rounded-xl border border-gray-200 bg-gray-50 p-6">
      <p class="text-sm text-gray-600">
        Need the verdict for a specific substance? Search it in the
        <a href={TOOL} class="font-semibold text-teal-700 hover:underline">storage compatibility matrix</a>.
      </p>
      <p class="mt-3 text-xs text-gray-400 leading-relaxed">
        Reference aid only — class-level segregation is a starting point, not a substitute for a substance's Safety
        Data Sheet or professional judgment. Always verify storage against SDS sections 7 and 10 and local regulations.
      </p>
    </section>
  </div>

  {jsonLd.map((block) => (
    <script type="application/ld+json" set:html={JSON.stringify(block)} />
  ))}

  <style is:global>
    #ss-list.ss-collapsed .ss-extra { display: none !important; }
  </style>
  <script is:inline>
    (function () {
      var b = document.getElementById('ss-toggle')
      var ul = document.getElementById('ss-list')
      if (!b || !ul) return
      b.addEventListener('click', function () {
        var collapsed = ul.classList.toggle('ss-collapsed')
        b.textContent = collapsed ? b.getAttribute('data-all') : 'Show fewer ↑'
      })
    })()
  </script>
</Layout>
