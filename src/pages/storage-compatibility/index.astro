---
// Storage-compatibility hub — /storage-compatibility/
// Directory of the 13 storage-class category pages. Signature colour: teal.
// Textured gradient hero (navy -> teal glow + dot overlay); restrained cards
// (neutral surface + one small muted hazard-family dot; teal is the accent).
import Layout from '../../layouts/Layout.astro'
import { STORAGE_CLASSES, familyStyleForCode, HERO_BG, HERO_DOTS } from '../../lib/storageClasses'
import { supabase } from '../../lib/supabase'

const SITE = 'https://ghspictograms.com'
const TOOL = '/tools/chemical-storage-compatibility/'

const cards = (
  await Promise.all(
    STORAGE_CLASSES.map(async (c) => {
      const { data } = await supabase.rpc('get_class_substances', { p_sc_code: c.code, p_limit: 0 })
      return { ...c, total: (data?.total as number | undefined) ?? 0, fam: familyStyleForCode(c.code) }
    }),
  )
).sort((a, b) => b.total - a.total)

const title = 'Chemical storage compatibility by hazard class'
const description =
  'Browse chemical storage segregation by hazard class — what each class can and cannot be stored with, and the substances in each. 13 storage classes, backed by GHS hazard data, chemical reactivity, and ADR transport.'
const canonical = `${SITE}/storage-compatibility/`

const stats = [
  { n: '13', label: 'Hazard classes' },
  { n: '3,652', label: 'Substances' },
  { n: 'GHS · CAMEO · ADR', label: 'Cross-referenced' },
  { n: 'Free', label: 'No signup' },
]

const jsonLd: Record<string, unknown>[] = [
  { '@context': 'https://schema.org', '@type': 'CollectionPage', name: title, description, url: canonical },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Storage hazard classes',
    numberOfItems: cards.length,
    itemListElement: cards.map((c, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: c.short,
      url: `${SITE}/storage-compatibility/${c.slug}/`,
    })),
  },
]

const heroBg = HERO_BG
const dotBg = HERO_DOTS
---

<Layout title={title} description={description} canonical={canonical}>
  <!-- HERO: textured gradient + dot overlay -->
  <section class="relative overflow-hidden text-white" style={`background:${heroBg};`}>
    <div class="absolute inset-0 opacity-40" style={`background-image:${dotBg};background-size:22px 22px;`} aria-hidden="true"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14 sm:py-16">
      <nav class="text-sm text-slate-300 mb-6" aria-label="Breadcrumb">
        <a href="/tools/" class="hover:text-white transition-colors">Tools</a>
        <span class="mx-1 text-slate-500">/</span>
        <span class="text-slate-200">Storage compatibility</span>
      </nav>
      <div class="flex items-start gap-4">
        <div class="hidden sm:flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-teal-500 shadow-lg shadow-teal-900/40">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="7" height="7" rx="1.5"></rect>
            <rect x="14" y="3" width="7" height="7" rx="1.5"></rect>
            <rect x="3" y="14" width="7" height="7" rx="1.5"></rect>
            <rect x="14" y="14" width="7" height="7" rx="1.5"></rect>
          </svg>
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-teal-300">Storage compatibility</p>
          <h1 class="mt-1.5 text-4xl sm:text-5xl font-extrabold tracking-tight leading-[1.05]" style="font-family:'Space Grotesk',sans-serif;">
            Chemical storage compatibility by hazard class
          </h1>
          <p class="mt-4 text-lg text-slate-200 max-w-3xl leading-relaxed">
            Chemicals are grouped into storage classes by their hazards, then segregated so incompatible classes
            aren't stored together. Pick a class to see what it can and can't be stored with — or check a specific
            substance in the matrix.
          </p>
          <a
            href={TOOL}
            class="mt-6 inline-flex items-center gap-1.5 rounded-lg bg-teal-500 px-4 py-2.5 text-sm font-semibold text-white shadow-md shadow-teal-900/30 hover:bg-teal-400 transition-colors"
          >
            Check a specific substance →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- STAT BAND -->
  <section class="border-b border-gray-100 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-2 sm:grid-cols-4 divide-x divide-gray-100">
      {stats.map((s) => (
        <div class="px-4 py-5 text-center">
          <p class="text-lg sm:text-xl font-extrabold text-teal-700" style="font-family:'Space Grotesk',sans-serif;">{s.n}</p>
          <p class="mt-0.5 text-xs uppercase tracking-wide text-gray-400">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CLASS CARDS: restrained (neutral surface, small muted family dot, teal accent) -->
  <section class="bg-slate-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {cards.map((c) => (
          <li>
            <a
              href={`/storage-compatibility/${c.slug}/`}
              class="group flex h-full flex-col justify-between rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition-all duration-150 hover:-translate-y-0.5 hover:border-teal-300 hover:shadow-md"
            >
              <div>
                <div class="flex items-center gap-2">
                  <span class={`h-2 w-2 rounded-full ${c.fam.dot}`} aria-hidden="true"></span>
                  <span class="text-[11px] font-semibold uppercase tracking-wide text-gray-400">{c.fam.label}</span>
                </div>
                <h2 class="mt-2.5 text-lg font-bold text-gray-900" style="font-family:'Space Grotesk',sans-serif;">
                  {c.short}
                </h2>
              </div>
              <div class="mt-5 flex items-center justify-between">
                <p class="text-sm text-gray-500">
                  <span class="font-bold text-teal-700">{c.total}</span>
                  {c.total === 1 ? ' substance' : ' substances'}
                </p>
                <span class="text-teal-600 transition-transform group-hover:translate-x-1" aria-hidden="true">→</span>
              </div>
            </a>
          </li>
        ))}
      </ul>

      <p class="mt-8 text-xs text-gray-400 leading-relaxed max-w-3xl">
        Reference aid only — storage-class segregation is a starting point, not a substitute for a substance's
        Safety Data Sheet or professional judgment. Always verify against SDS sections 7 and 10 and local regulations.
      </p>
    </div>
  </section>

  {jsonLd.map((block) => (
    <script type="application/ld+json" set:html={JSON.stringify(block)} />
  ))}
</Layout>
