---
/**
 * On-demand SSR: нет getStaticPaths — не тратим 5‑минутный prerender Cloudflare на тысячи страниц.
 * Кеш — на стороне Cloudflare (Cache Rules / fetch cache). Список TOP‑200 CAS для прогрева:
 * `topCasNumbersForWarmup` в src/lib/pictogramCasPaths.ts (после однократной выборки веществ).
 *
 * Важно: при `prerender = true` и неполном getStaticPaths Astro не отдаёт остальные пути через SSR
 * для того же файла — будет 404. Поэтому гибрид «200 static + остальные SSR» в одном [cas].astro невозможен.
 */
export const prerender = false

import Layout from '../../layouts/Layout.astro'
import { supabase } from '../../lib/supabase'
import {
  filterLabelPictogramCodes,
  type HPRowLite,
  type PictogramRow,
  type RelatedProp,
  type SubstanceRow,
} from '../../lib/pictogramCasPaths'

type PageMode = 'missing_param' | 'substance_not_found' | 'no_pictograms' | 'ok'

const casParam = Astro.params.cas
const casRaw = casParam ? decodeURIComponent(casParam) : ''

let substance: SubstanceRow | null = null
let pageMode: PageMode

if (!casParam) {
  pageMode = 'missing_param'
} else {
  const { data: subData } = await supabase
    .from('substances')
    .select(
      'cas_number, common_name, iupac_name, ghs_pictogram_codes, h_statement_codes, p_statement_codes, signal_word, ec_number'
    )
    .eq('cas_number', casRaw)
    .maybeSingle()

  substance = (subData as SubstanceRow | null) ?? null

  if (!substance) {
    pageMode = 'substance_not_found'
  } else if (!(substance.ghs_pictogram_codes?.length ?? 0)) {
    pageMode = 'no_pictograms'
  } else {
    pageMode = 'ok'
  }
}

if (pageMode === 'missing_param' || pageMode === 'substance_not_found') {
  Astro.response.status = 404
}

const pictogramMeaningShort: Record<string, string> = {
  GHS01: 'Explosive substances — avoid shock, heat, ignition.',
  GHS02: 'Flammable — keep away from heat and ignition sources.',
  GHS03: 'Oxidising — intensifies fire; segregate from flammables.',
  GHS04: 'Gas under pressure — protect cylinders, avoid heat.',
  GHS05: 'Corrosive — skin, eye, or metal damage; use PPE.',
  GHS06: 'Acute toxicity — severe harm from short exposure.',
  GHS07: 'Irritation or less severe acute toxicity — follow SDS.',
  GHS08: 'Serious long-term health hazards (CMR, STOT, etc.).',
  GHS09: 'Hazardous to the aquatic environment — prevent releases.',
}

function captionForPictogram(code: string, hazardClassEn: string | null): string {
  if (hazardClassEn && hazardClassEn.trim().length > 24) {
    const s = hazardClassEn.trim()
    return s.length <= 220 ? s : `${s.slice(0, 200).trim()}…`
  }
  return (
    pictogramMeaningShort[code] ??
    'GHS hazard pictogram — use official classification and SDS for labelling.'
  )
}

function buildSeoTitle(displayName: string): string {
  const suffix = ' GHS Pictograms — Download SVG | GHSPictograms'
  const max = 60
  let full = `${displayName}${suffix}`
  if (full.length <= max) return full
  const maxName = Math.max(8, max - suffix.length - 3)
  const namePart =
    displayName.length > maxName
      ? `${displayName.slice(0, maxName - 3)}...`
      : displayName
  full = `${namePart}${suffix}`
  return full.length > max ? full.slice(0, max) : full
}

function buildSeoDescription(displayName: string, casNum: string): string {
  const raw = `Free SVG downloads of GHS hazard pictograms for ${displayName} (CAS ${casNum}). Label size specifications and CLP-compliant label builder.`
  const max = 155
  if (raw.length <= max) return raw
  const trimmed = `${displayName} (CAS ${casNum}). Label size specs & CLP label builder — free SVG GHS pictograms.`
  if (trimmed.length <= max) return trimmed
  return `${trimmed.slice(0, max - 1)}…`
}

function textSnippet(text: string, max = 130): string {
  const t = text.trim().replace(/\s+/g, ' ')
  return t.length <= max ? t : `${t.slice(0, max - 1)}…`
}

const ogImage = 'https://ghspictograms.com/og-default.png'

let seoTitle = 'Substance not found | GHSPictograms'
let seoDescription =
  'That CAS is not present in our harmonised CLP database on GHSPictograms.'
let canonical = 'https://ghspictograms.com/pictograms/'
let productJsonLd = ''

let cas = ''
let displayName = ''
let casEnc = ''
let labelPictograms: PictogramRow[] = []
let excludedPictograms: PictogramRow[] = []
let related: RelatedProp[] = []
let hPreview: HPRowLite[] = []
let pPreview: HPRowLite[] = []
let substanceEc: string | null = null
let substanceSignalWord: string | null = null
let hStatementsTotal = 0
let pStatementsTotal = 0

if (pageMode === 'missing_param') {
  seoTitle = 'Substance not found | GHSPictograms'
  seoDescription = 'Missing CAS in the URL. Browse substances from the pictograms directory.'
}

if (pageMode === 'substance_not_found' && casRaw) {
  const casSlugEnc = encodeURIComponent(casRaw)
  canonical = `https://ghspictograms.com/pictograms/${casSlugEnc}/`
  seoTitle = `Substance not found (CAS ${casRaw}) | GHSPictograms`
  seoDescription = `CAS ${casRaw} was not found in our harmonised database. Try GHSSymbols for broader hazard data or another CAS spelling.`
}

if (pageMode === 'no_pictograms' && substance) {
  cas = substance.cas_number
  displayName = substance.common_name || substance.iupac_name
  casEnc = encodeURIComponent(cas)
  canonical = `https://ghspictograms.com/pictograms/${casEnc}/`
  seoTitle = `${displayName} — no pictogram data yet | GHSPictograms`
  if (seoTitle.length > 62) seoTitle = `CAS ${cas} — no pictograms | GHSPictograms`
  seoDescription = `Harmonised entry for CAS ${cas} has no GHS pictogram codes in our dataset yet. View hazard statements on GHSSymbols.`
  substanceEc = substance.ec_number
  substanceSignalWord = substance.signal_word
}

if (pageMode === 'ok' && substance) {
  const picCodes = substance.ghs_pictogram_codes ?? []
  const hCodes = substance.h_statement_codes ?? []
  const pCodes = substance.p_statement_codes ?? []

  const [picRes, hRes, pRes] = await Promise.all([
    picCodes.length
      ? supabase
          .from('pictograms_signals')
          .select('code, name_en, svg_content, hazard_class_en')
          .in('code', picCodes)
      : Promise.resolve({ data: null as PictogramRow[] | null }),
    hCodes.length
      ? supabase.from('h_statements').select('code, text_en').in('code', hCodes)
      : Promise.resolve({ data: null as HPRowLite[] | null }),
    pCodes.length
      ? supabase.from('p_statements').select('code, text_en').in('code', pCodes)
      : Promise.resolve({ data: null as HPRowLite[] | null }),
  ])

  const picByCode = new Map(((picRes.data ?? []) as PictogramRow[]).map((p) => [p.code, p]))

  const hByCode = new Map(((hRes.data ?? []) as HPRowLite[]).map((h) => [h.code, h]))
  const hList = hCodes
    .map((c) => hByCode.get(c))
    .filter((h): h is HPRowLite => h != null)

  const pByCode = new Map(((pRes.data ?? []) as HPRowLite[]).map((p) => [p.code, p]))
  const pList = pCodes
    .map((c) => pByCode.get(c))
    .filter((p): p is HPRowLite => p != null)

  if (picCodes.length > 0) {
    const { data: overlapRows } = await supabase
      .from('substances')
      .select('cas_number, common_name, iupac_name, ghs_pictogram_codes')
      .overlaps('ghs_pictogram_codes', picCodes)
      .neq('cas_number', substance.cas_number)
      .limit(100)

    const picSet = new Set(picCodes)
    type OverlapRow = {
      cas_number: string
      common_name: string | null
      iupac_name: string
      ghs_pictogram_codes: string[] | null
    }
    related = ((overlapRows ?? []) as OverlapRow[])
      .map((o) => ({
        o,
        score: (o.ghs_pictogram_codes ?? []).reduce(
          (n, c) => n + (picSet.has(c) ? 1 : 0),
          0
        ),
      }))
      .filter((x) => x.score > 0)
      .sort(
        (a, b) =>
          b.score - a.score ||
          a.o.cas_number.localeCompare(b.o.cas_number, undefined, {
            numeric: true,
          })
      )
      .slice(0, 6)
      .map(({ o }) => ({
        cas_number: o.cas_number,
        common_name: o.common_name,
        iupac_name: o.iupac_name,
      }))
  }

  const allPicCodes = substance.ghs_pictogram_codes ?? []
  const filteredCodes = filterLabelPictogramCodes(allPicCodes)
  labelPictograms = filteredCodes
    .map((c) => picByCode.get(c))
    .filter((p): p is PictogramRow => p != null)
  excludedPictograms = allPicCodes
    .filter((c) => !filteredCodes.includes(c))
    .map((c) => picByCode.get(c))
    .filter((p): p is PictogramRow => p != null)
    .sort((a, b) => a.code.localeCompare(b.code))

  cas = substance.cas_number
  displayName = substance.common_name || substance.iupac_name
  casEnc = encodeURIComponent(cas)

  seoTitle = buildSeoTitle(displayName)
  seoDescription = buildSeoDescription(displayName, cas)
  canonical = `https://ghspictograms.com/pictograms/${casEnc}/`

  productJsonLd = JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: `${displayName} — GHS pictogram SVG pack & label specs`,
    description: seoDescription,
    image: ogImage,
    sku: cas,
    brand: { '@type': 'Brand', name: 'GHS Pictograms' },
    category: 'GHSLabelDesignResource',
    additionalProperty: [
      { '@type': 'PropertyValue', name: 'CAS', value: cas },
      ...(substance.ec_number
        ? [{ '@type': 'PropertyValue', name: 'EC', value: substance.ec_number }]
        : []),
    ],
  })

  hPreview = hList.slice(0, 12)
  pPreview = pList.slice(0, 12)
  substanceEc = substance.ec_number
  substanceSignalWord = substance.signal_word
  hStatementsTotal = substance.h_statement_codes?.length ?? 0
  pStatementsTotal = substance.p_statement_codes?.length ?? 0
}

const showNotFoundUi = pageMode === 'missing_param' || pageMode === 'substance_not_found'
---


<Layout
  title={seoTitle}
  description={seoDescription}
  titleIsComplete={true}
  canonical={canonical}
  image={ogImage}
>
  {pageMode === 'ok' && productJsonLd ? (
    <script type="application/ld+json" slot="head" set:html={productJsonLd} />
  ) : null}

  {showNotFoundUi ? (
    <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
      <nav class="text-sm text-gray-500 mb-8" aria-label="Breadcrumb">
        <a href="/pictograms/" class="text-[#062A78] hover:underline">Pictograms</a>
        <span class="mx-2">/</span>
        <span class="text-gray-700 font-mono">
          {pageMode === 'substance_not_found' ? casRaw : '—'}
        </span>
      </nav>

      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 tracking-tight">Substance not found</h1>
      <p class="mt-4 text-gray-600 max-w-2xl">
        {pageMode === 'missing_param'
          ? 'This URL does not include a valid CAS identifier. Go back to the pictograms browser and choose a substance.'
          : `We do not have a harmonised substance row for CAS ${casRaw} in GHSPictograms yet. Check the CAS format or try GHSSymbols for hazard pages.`}
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="/pictograms/"
          class="inline-flex items-center px-5 py-2.5 rounded-lg bg-[#062A78] text-white font-semibold text-sm hover:bg-blue-900"
        >
          Browse pictograms directory
        </a>
        {pageMode === 'substance_not_found' && casRaw ? (
          <a
            href={`https://ghssymbols.com/hazards/${encodeURIComponent(casRaw)}/`}
            class="inline-flex items-center px-5 py-2.5 rounded-lg border-2 border-[#062A78] text-[#062A78] font-semibold text-sm hover:bg-[#062A78]/5"
            target="_blank"
            rel="noopener noreferrer"
          >
            Try GHSSymbols hazard page for CAS {casRaw}
          </a>
        ) : null}
      </div>
      <p class="mt-10 text-xs text-gray-500">HTTP 404 — page not found in this database snapshot.</p>
    </article>
  ) : null}

  {pageMode === 'no_pictograms' ? (
    <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
      <nav class="text-sm text-gray-500 mb-8" aria-label="Breadcrumb">
        <a href="/pictograms/" class="text-[#062A78] hover:underline">Pictograms</a>
        <span class="mx-2">/</span>
        <span class="text-gray-700 font-mono">{cas}</span>
      </nav>

      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 tracking-tight leading-tight">
        {displayName}
      </h1>
      <p class="mt-3 text-sm text-gray-600">
        <span class="font-medium text-gray-800">CAS</span> {cas}
        {substanceEc ? (
          <>
            <span class="mx-2">·</span>
            <span class="font-medium text-gray-800">EC</span> {substanceEc}
          </>
        ) : null}
        {substanceSignalWord ? (
          <>
            <span class="mx-2">·</span>
            <span class="font-medium text-amber-800">Signal word</span> {substanceSignalWord}
          </>
        ) : null}
      </p>

      <div class="mt-10 rounded-2xl border border-amber-200 bg-amber-50 p-6 sm:p-8">
        <h2 class="text-xl font-bold text-gray-900">No pictograms data available</h2>
        <p class="mt-3 text-gray-700 max-w-2xl">
          This harmonised entry has no GHS pictogram codes in our dataset. You can still open the full hazard page on GHSSymbols
          (H and P phrases, signal word, and more).
        </p>
        <a
          href={`https://ghssymbols.com/hazards/${casEnc}/`}
          class="mt-6 inline-flex items-center px-6 py-3 rounded-xl bg-[#062A78] text-white font-bold text-base hover:bg-blue-900"
          target="_blank"
          rel="noopener noreferrer"
        >
          Open hazard classification on GHSSymbols.com →
        </a>
      </div>

      <p class="mt-12 text-xs text-gray-500">
        Information is for reference only — confirm classification on your SDS and the official CLP text.
      </p>
    </article>
  ) : null}

  {pageMode === 'ok' ? (
    <>
      <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="Breadcrumb">
      <a href="/pictograms/" class="text-[#062A78] hover:underline">Pictograms</a>
      <span class="mx-2">/</span>
      <span class="text-gray-700 font-mono">{cas}</span>
    </nav>

    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 tracking-tight leading-tight">
      {displayName} — GHS Pictograms &amp; Label Specifications
    </h1>
    <p class="mt-3 text-sm text-gray-600">
      <span class="font-medium text-gray-800">CAS</span> {cas}
      {substanceEc && (
        <>
          <span class="mx-2">·</span>
          <span class="font-medium text-gray-800">EC</span> {substanceEc}
        </>
      )}
      {substanceSignalWord && (
        <>
          <span class="mx-2">·</span>
          <span class="font-medium text-amber-800">Signal word</span>{' '}
          {substanceSignalWord}
        </>
      )}
    </p>

    <section class="mt-12" aria-labelledby="pictograms-heading">
      <h2 id="pictograms-heading" class="text-2xl font-bold text-gray-900 mb-2">
        Hazard Pictograms for {displayName}
      </h2>
      <p class="text-gray-600 mb-8 max-w-3xl">
        Use these pictograms when labeling containers of {displayName}. Download vector SVGs for Adobe Illustrator, packaging
        design, and print workflows.
      </p>

      {labelPictograms.length === 0 ? (
        <p class="text-gray-600">No pictogram graphics are available for this entry.</p>
      ) : (
        <ul class="grid sm:grid-cols-2 gap-8 list-none p-0">
          {labelPictograms.map((p) => (
            <li class="pictogram-svg-card border border-gray-200 rounded-2xl p-6 bg-white shadow-sm">
              <div
                class="svg-source mx-auto flex items-center justify-center [&>svg]:max-w-[200px] [&>svg]:max-h-[200px] [&>svg]:w-full [&>svg]:h-auto"
                style="width:200px;height:200px;"
                set:html={p.svg_content ?? ''}
              />
              <p class="text-center font-mono font-bold text-gray-900 mt-4">{p.code}</p>
              <p class="text-center text-lg font-semibold text-[#062A78] mt-1">{p.name_en}</p>
              <p class="text-sm text-gray-600 mt-3 text-center leading-relaxed px-2">
                {captionForPictogram(p.code, p.hazard_class_en)}
              </p>
              <div class="mt-5 flex justify-center">
                <button
                  type="button"
                  class="download-svg-btn px-4 py-2 rounded-lg border-2 border-[#062A78] text-[#062A78] font-semibold text-sm hover:bg-[#062A78] hover:text-white transition-colors"
                  data-download-code={p.code}
                >
                  Download SVG
                </button>
              </div>
            </li>
          ))}
        </ul>
      )}
    </section>

    {excludedPictograms.length > 0 && (
      <div class="mt-10 bg-slate-50 border border-slate-200 rounded-xl p-4 text-sm">
        <p class="font-semibold text-gray-800 mb-2">CLP precedence (label display)</p>
        <p class="text-gray-600 mb-2">
          Some assigned codes are omitted on the harmonised label when a more severe pictogram applies (e.g. GHS07 vs GHS06).
        </p>
        <ul class="space-y-1 text-gray-600">
          {excludedPictograms.map((p) => (
            <li>
              <span class="font-mono font-semibold text-gray-800">{p.code}</span> — {p.name_en}
            </li>
          ))}
        </ul>
      </div>
    )}

    <section class="mt-16" aria-labelledby="label-size-heading">
      <h2 id="label-size-heading" class="text-2xl font-bold text-gray-900 mb-2">
        Label Size Requirements (CLP Annex I, Table 1.3)
      </h2>
      <p class="text-gray-600 mb-6 text-sm">
        Indicative minimum dimensions for the label and GHS pictogram on the package (verify against the current CLP text and
        your package shape).
      </p>
      <div class="overflow-x-auto rounded-xl border border-gray-200">
        <table class="w-full text-sm text-left">
          <thead class="bg-slate-100 text-gray-900 font-semibold">
            <tr>
              <th class="px-4 py-3">Package capacity</th>
              <th class="px-4 py-3">Minimum label size (not folded)</th>
              <th class="px-4 py-3">Minimum pictogram size</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <tr>
              <td class="px-4 py-3">≤ 0.5 L</td>
              <td class="px-4 py-3">52 × 74 mm</td>
              <td class="px-4 py-3">16 × 16 mm</td>
            </tr>
            <tr class="bg-slate-50/60">
              <td class="px-4 py-3">0.5–3 L</td>
              <td class="px-4 py-3">74 × 105 mm</td>
              <td class="px-4 py-3">23 × 23 mm</td>
            </tr>
            <tr>
              <td class="px-4 py-3">3–50 L</td>
              <td class="px-4 py-3">105 × 148 mm</td>
              <td class="px-4 py-3">32 × 32 mm</td>
            </tr>
            <tr class="bg-slate-50/60">
              <td class="px-4 py-3">50–500 L</td>
              <td class="px-4 py-3">148 × 210 mm</td>
              <td class="px-4 py-3">46 × 46 mm</td>
            </tr>
            <tr>
              <td class="px-4 py-3">&gt; 500 L</td>
              <td class="px-4 py-3">210 × 297 mm</td>
              <td class="px-4 py-3">64 × 64 mm</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-14 rounded-2xl bg-amber-50 border border-amber-200 p-8 text-center" aria-label="Label builder call to action">
      <a
        href={`/label-constructor/?cas=${casEnc}`}
        class="inline-block px-8 py-4 rounded-xl bg-[#062A78] text-white font-bold text-lg hover:bg-blue-900 transition-colors shadow-md"
      >
        Build a CLP-Compliant Label for {displayName} →
      </a>
      <p class="mt-5">
        <a
          href={`https://ghssymbols.com/hazards/${casEnc}/`}
          class="text-sm font-semibold text-[#062A78] hover:underline"
          target="_blank"
          rel="noopener noreferrer"
        >
          View hazard classification on GHSSymbols.com →
        </a>
      </p>
    </section>

    {hPreview.length > 0 && (
      <section class="mt-16" aria-labelledby="hazard-statements-heading">
        <h2 id="hazard-statements-heading" class="text-2xl font-bold text-gray-900 mb-4">
          Hazard Statements
        </h2>
        <p class="text-gray-600 text-sm mb-4">
          Harmonised hazard statements associated with this entry (short preview for label context; always confirm on the SDS).
        </p>
        <ul class="space-y-3 list-none p-0">
          {hPreview.map((h) => (
            <li class="border border-gray-100 rounded-lg p-4 bg-gray-50/80">
              <span class="font-mono font-bold text-[#062A78]">{h.code}</span>
              {h.text_en ? (
                <span class="text-gray-700 text-sm ml-2">{textSnippet(h.text_en)}</span>
              ) : (
                <span class="text-gray-500 text-sm ml-2">(wording in safety data sheet)</span>
              )}
            </li>
          ))}
        </ul>
        {hStatementsTotal > 12 && (
          <p class="mt-3 text-sm text-gray-500">
            Showing 12 of {hStatementsTotal} hazard statements — see full classification on the SDS or GHS Symbols.
          </p>
        )}
      </section>
    )}

    {pPreview.length > 0 && (
      <section class="mt-16" aria-labelledby="p-statements-heading">
        <h2 id="p-statements-heading" class="text-2xl font-bold text-gray-900 mb-4">
          Precautionary Statements (preview)
        </h2>
        <p class="text-gray-600 text-sm mb-4">Label-oriented P-phrases — confirm full wording on the SDS.</p>
        <ul class="space-y-3 list-none p-0">
          {pPreview.map((pRow) => (
            <li class="border border-gray-100 rounded-lg p-4 bg-teal-50/40">
              <span class="font-mono font-bold text-teal-900">{pRow.code}</span>
              {pRow.text_en ? (
                <span class="text-gray-700 text-sm ml-2">{textSnippet(pRow.text_en)}</span>
              ) : (
                <span class="text-gray-500 text-sm ml-2">(wording in safety data sheet)</span>
              )}
            </li>
          ))}
        </ul>
        {pStatementsTotal > 12 && (
          <p class="mt-3 text-sm text-gray-500">Showing 12 of {pStatementsTotal} precautionary statements.</p>
        )}
      </section>
    )}

    {related.length > 0 && (
      <section class="mt-16 border-t border-gray-200 pt-10" aria-labelledby="related-heading">
        <h2 id="related-heading" class="text-2xl font-bold text-gray-900 mb-4">
          Related Substances with Same Pictograms
        </h2>
        <p class="text-gray-600 text-sm mb-6">
          Other harmonised entries sharing GHS pictogram codes with {displayName} (by overlap score).
        </p>
        <div class="grid sm:grid-cols-2 gap-4">
          {related.map((r) => (
            <a
              href={`/pictograms/${encodeURIComponent(r.cas_number)}/`}
              class="block border border-gray-200 rounded-xl p-4 hover:bg-amber-50/50 hover:border-amber-200 transition-colors"
            >
              <div class="font-semibold text-gray-900 text-sm line-clamp-2">
                {r.common_name || r.iupac_name}
              </div>
              <div class="text-xs text-gray-500 mt-1 font-mono">CAS {r.cas_number}</div>
            </a>
          ))}
        </div>
      </section>
    )}

    <p class="mt-14 text-xs text-gray-500">
      Information is for design and training reference only. Verify dimensions, classification, and label content against the
      official CLP text, your SDS, and national law.
    </p>
      </article>

      <script is:inline>
        (function () {
          document.querySelectorAll('.download-svg-btn').forEach(function (button) {
            button.addEventListener('click', function () {
              var card = button.closest('.pictogram-svg-card')
              if (!card) return
              var el = card.querySelector('.svg-source')
              if (!el) return
              var svg = el.innerHTML.trim()
              if (!svg) return
              var code = button.getAttribute('data-download-code') || 'ghs-pictogram'
              var xml =
                '<?xml version="1.0" encoding="UTF-8"?>' +
                (svg.indexOf('<svg') === 0 ? svg : '<svg xmlns="http://www.w3.org/2000/svg">' + svg + '</svg>')
              try {
                var blob = new Blob([xml], { type: 'image/svg+xml;charset=utf-8' })
                var url = URL.createObjectURL(blob)
                var a = document.createElement('a')
                a.href = url
                a.download = code + '.svg'
                a.click()
                URL.revokeObjectURL(url)
              } catch (e) {}
            })
          })
        })()
      </script>
    </>
  ) : null}
</Layout>
