---
export const prerender = true
// ghspictograms.com — главная (светлая тема, Space Grotesk + Inter)
import '../styles/global.css'
import { Fragment } from 'astro/jsx-runtime'
import { supabase } from '../lib/supabase'

const stats = [
  { value: '4,178', label: 'Substances' },
  { value: '9', label: 'GHS Pictograms' },
  { value: 'CLP/GHS', label: 'EU Compliant' },
  { value: 'Free · No Registration', label: '' },
]

/**
 * pictograms_signals: id (= pictogram_id в смысле записи), code, name_en, svg_content, svg_url
 * (полей pictogram_id / name в таблице нет — см. supabase/schema.sql)
 */
const { data: pictogramsRaw, error: pictogramsError } = await supabase
  .from('pictograms_signals')
  .select('id, code, name_en, svg_url, svg_content')
  .order('code', { ascending: true })
  .limit(9)

if (pictogramsError) {
  console.error('[index] pictograms_signals:', pictogramsError.message)
}

const pictogramsRows = pictogramsRaw ?? []

const tools = [
  {
    title: 'GHS Label Constructor',
    description:
      'Build compliant GHS labels in 5 steps. Add pictograms, H-statements, P-statements, supplier info. Export ready-to-print PDF.',
    href: '/label-constructor/',
    badge: 'BETA',
    cta: 'Build Label →',
  },
  {
    title: 'Substance Database',
    description:
      'Browse GHS01–GHS09 pictograms for 4,178 classified substances. Find the correct hazard symbols for any chemical by CAS number.',
    href: '/pictograms/',
    badge: '4,178 SUBSTANCES',
    cta: 'Browse Database →',
  },
  {
    title: 'GHS vs ADR/DOT Inspector',
    description:
      'Compare workplace GHS labels vs transport placards side-by-side. Essential for logistics and distribution compliance.',
    href: '/inspector/',
    badge: 'NEW',
    cta: 'Try Inspector →',
  },
]
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GHS Pictograms — Label Constructor & Hazard Symbol Library</title>
    <meta
      name="description"
      content="Professional GHS pictogram library and label builder for 4,178 classified substances. CLP Annex VI data, CLP/GHS compliant tools."
    />
    <link rel="canonical" href="https://ghspictograms.com/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <meta property="og:title" content="GHS Pictograms — Label Constructor & Library" />
    <meta
      property="og:description"
      content="Pictogram library and label constructor for 4,178 substances. CLP Annex VI."
    />
    <meta property="og:url" content="https://ghspictograms.com/" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://ghspictograms.com/og-default.png" />
    <meta property="og:site_name" content="GHS Pictograms" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="GHS Pictograms — Label Constructor & Library" />
    <meta
      name="twitter:description"
      content="Pictogram library and label constructor for 4,178 substances. CLP Annex VI."
    />
    <meta name="twitter:image" content="https://ghspictograms.com/og-default.png" />

    <style>
      :root {
        --nav: #062a78;
        --nav-dark: #0a3a8c;
        --accent: #0077b6;
        --body: #ffffff;
        --card: #f8fafc;
        --card-border: #e2e8f0;
        --text: #1e293b;
        --muted: #64748b;
        --font-heading: 'Space Grotesk', system-ui, sans-serif;
        --font-body: 'Inter', system-ui, sans-serif;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: var(--font-body);
        font-size: 16px;
        line-height: 1.6;
        color: var(--text);
        background: var(--body);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .font-heading {
        font-family: var(--font-heading);
      }

      /* ——— Hero ——— */
      .hero {
        background: linear-gradient(180deg, var(--nav) 0%, var(--nav-dark) 100%);
        color: #fff;
        padding: 3.5rem 1.5rem 4rem;
      }

      .hero-inner {
        max-width: 1120px;
        margin: 0 auto;
      }

      .hero-eyebrow {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.75);
        margin-bottom: 1.25rem;
      }

      .hero-eyebrow::before {
        content: '';
        width: 32px;
        height: 1px;
        background: rgba(255, 255, 255, 0.45);
      }

      .hero h1 {
        font-family: var(--font-heading);
        font-size: clamp(2.25rem, 5vw, 3.25rem);
        font-weight: 700;
        line-height: 1.15;
        letter-spacing: -0.02em;
        margin-bottom: 1rem;
      }

      .hero h1 .hero-accent {
        color: var(--accent);
      }

      .hero-sub {
        font-size: 1.125rem;
        color: rgba(255, 255, 255, 0.85);
        max-width: 36rem;
        margin-bottom: 1.75rem;
        line-height: 1.65;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-bottom: 2.5rem;
      }

      .btn-primary-hero {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--accent);
        color: #fff;
        font-weight: 600;
        font-size: 0.9375rem;
        padding: 0.75rem 1.35rem;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        transition: filter 0.15s;
      }

      .btn-primary-hero:hover {
        filter: brightness(1.06);
      }

      .btn-outline-hero {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-weight: 600;
        font-size: 0.9375rem;
        padding: 0.75rem 1.35rem;
        border-radius: 8px;
        border: 2px solid rgba(255, 255, 255, 0.85);
        background: transparent;
        transition:
          background 0.15s,
          border-color 0.15s;
      }

      .btn-outline-hero:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: #fff;
      }

      /* ——— Stats ——— */
      .stats-bar {
        background: #fff;
        border-bottom: 1px solid var(--card-border);
      }

      .stats-inner {
        max-width: 1120px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        padding: 0 1.5rem;
      }

      .stat-cell {
        text-align: center;
        padding: 1.75rem 1rem;
        border-right: 1px solid var(--card-border);
      }

      .stat-cell:last-child {
        border-right: none;
      }

      .stat-value {
        font-family: var(--font-heading);
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--accent);
        letter-spacing: 0.02em;
      }

      .stat-label {
        font-size: 0.8125rem;
        color: var(--muted);
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-top: 0.25rem;
      }

      /* ——— Sections ——— */
      .section {
        padding: 3.5rem 1.5rem;
        max-width: 1120px;
        margin: 0 auto;
      }

      .section-label {
        font-size: 0.6875rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .section-label::before {
        content: '';
        width: 20px;
        height: 1px;
        background: var(--card-border);
      }

      .section-title {
        font-family: var(--font-heading);
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 1.75rem;
        letter-spacing: -0.02em;
      }

      /* Pictogram grid */
      .p-grid {
        display: grid;
        grid-template-columns: repeat(9, minmax(0, 1fr));
        gap: 0.75rem;
      }

      .p-card {
        display: block;
        background: var(--card);
        border: 1px solid var(--card-border);
        border-radius: 8px;
        padding: 1rem 0.5rem;
        text-align: center;
        transition: border-color 0.2s;
        min-width: 0;
        cursor: pointer;
      }

      .p-card:hover {
        border-color: #0077b6;
      }

      .p-card-svg {
        width: 100%;
        max-width: 72px;
        height: 72px;
        margin: 0 auto 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .p-card-svg :global(svg) {
        max-width: 100%;
        max-height: 100%;
      }

      .p-card-svg img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
      }

      .p-code {
        font-size: 0.6875rem;
        font-weight: 600;
        color: var(--muted);
        font-family: ui-monospace, monospace;
      }

      .p-name {
        display: block;
        font-size: 0.6875rem;
        color: var(--text);
        margin-top: 0.2rem;
        line-height: 1.3;
      }

      /* Search */
      .search-wrap {
        position: relative;
        max-width: 640px;
      }

      .search-wrap .search-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--muted);
        font-size: 1rem;
        pointer-events: none;
      }

      .search-form input[type='search'] {
        width: 100%;
        padding: 1rem 1rem 1rem 2.75rem;
        border: 1px solid var(--card-border);
        border-radius: 8px;
        font-family: var(--font-body);
        font-size: 1rem;
        color: var(--text);
        background: #fff;
        outline: none;
        transition: border-color 0.15s;
      }

      .search-form input[type='search']:focus {
        border-color: var(--accent);
      }

      .search-form input[type='search']::placeholder {
        color: #94a3b8;
      }

      .search-hint {
        margin-top: 0.75rem;
        font-size: 0.875rem;
        color: var(--muted);
      }

      .search-hint a {
        color: var(--accent);
        font-weight: 500;
      }

      .search-hint a:hover {
        text-decoration: underline;
      }

      /* Tools */
      .tools-section {
        background: var(--card);
        padding: 3.5rem 1.5rem;
      }

      .tools-inner {
        max-width: 1120px;
        margin: 0 auto;
      }

      .tools-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
      }

      .tool-card {
        background: #fff;
        border: 1px solid var(--card-border);
        border-radius: 12px;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        height: 100%;
      }

      .tool-badge {
        font-size: 0.625rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--accent);
        border: 1px solid rgba(0, 119, 182, 0.35);
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        width: fit-content;
      }

      .tool-badge--new {
        color: #15803d;
        border-color: rgba(22, 163, 74, 0.45);
        background: rgba(22, 163, 74, 0.1);
      }

      .tool-title {
        font-family: var(--font-heading);
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text);
      }

      .tool-desc {
        font-size: 0.875rem;
        color: var(--muted);
        line-height: 1.6;
        flex: 1;
      }

      .tool-cta {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--accent);
      }

      .tool-cta:hover {
        text-decoration: underline;
      }

      /* Sister */
      .sister {
        background: var(--nav);
        color: #fff;
        padding: 2.5rem 1.5rem;
      }

      .sister-inner {
        max-width: 1120px;
        margin: 0 auto;
        border-left: 4px solid var(--accent);
        padding-left: 1.5rem;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
      }

      .sister h3 {
        font-family: var(--font-heading);
        font-size: 1.35rem;
        font-weight: 700;
        margin-bottom: 0.35rem;
      }

      .sister p {
        font-size: 0.9375rem;
        color: rgba(255, 255, 255, 0.85);
        max-width: 36rem;
        line-height: 1.6;
      }

      .btn-sister {
        display: inline-flex;
        align-items: center;
        padding: 0.65rem 1.25rem;
        border: 2px solid #fff;
        border-radius: 8px;
        color: #fff;
        font-weight: 600;
        font-size: 0.875rem;
        white-space: nowrap;
        transition: background 0.15s;
      }

      .btn-sister:hover {
        background: rgba(255, 255, 255, 0.12);
      }

      /* Footer */
      .site-footer {
        background: var(--nav);
        color: rgba(255, 255, 255, 0.85);
        padding: 2rem 1.5rem;
      }

      .footer-inner {
        max-width: 1120px;
        margin: 0 auto;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .footer-logo {
        font-family: var(--font-heading);
        font-size: 0.9375rem;
      }

      .footer-logo .logo-ghs {
        font-weight: 500;
        color: #fff;
      }

      .footer-logo .logo-pictograms {
        font-weight: 700;
        color: #fff;
      }

      .footer-logo .logo-com {
        font-weight: 400;
        color: rgba(255, 255, 255, 0.6);
      }

      .footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 1.25rem;
        list-style: none;
      }

      .footer-links a {
        font-size: 0.8125rem;
        color: rgba(255, 255, 255, 0.8);
      }

      .footer-links a:hover {
        color: #fff;
      }

      .footer-copy {
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.55);
        width: 100%;
        flex-basis: 100%;
      }

      @media (max-width: 1024px) {
        .p-grid {
          grid-template-columns: repeat(5, minmax(0, 1fr));
        }
      }

      @media (max-width: 768px) {
        .stats-inner {
          grid-template-columns: repeat(2, 1fr);
        }

        .stat-cell:nth-child(2) {
          border-right: none;
        }

        .stat-cell:nth-child(1),
        .stat-cell:nth-child(2) {
          border-bottom: 1px solid var(--card-border);
        }

        .p-grid {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .tools-grid {
          grid-template-columns: 1fr;
        }

        .sister-inner {
          flex-direction: column;
          align-items: flex-start;
        }
      }
    </style>
  </head>
  <body>
    <header style="background:#062A78;position:sticky;top:0;z-index:50;">
      <nav style="max-width:1120px;margin:0 auto;padding:0 1.5rem;height:64px;display:flex;align-items:center;justify-content:space-between;">
        <a href="/" style="color:white;font-weight:700;font-size:1.1rem;font-family:var(--font-heading);">GHSPICTOGRAMS.COM</a>
        <ul id="desktop-nav" style="display:flex;align-items:center;gap:1rem;list-style:none;margin:0;padding:0;">
          <li><a href="/pictograms/" style="color:rgba(255,255,255,0.8);font-size:0.875rem;font-weight:500;">Substance Database</a></li>
          <li><a href="/inspector/" style="color:rgba(255,255,255,0.8);font-size:0.875rem;font-weight:500;">Inspector</a></li>
          <li><a href="/blog/" style="color:rgba(255,255,255,0.8);font-size:0.875rem;font-weight:500;">Blog</a></li>
          <li><a href="/faq/" style="color:rgba(255,255,255,0.8);font-size:0.875rem;font-weight:500;">FAQ</a></li>
          <li><a href="/label-constructor/" style="background:white;color:#062A78;font-weight:700;padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.875rem;">Build Label →</a></li>
        </ul>
        <button id="idx-burger" aria-label="Open menu" style="display:none;background:none;border:none;cursor:pointer;padding:0.5rem;">
          <svg width="28" height="28" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </nav>
      <div id="idx-mobile-menu" style="display:none;background:#062A78;border-top:1px solid rgba(255,255,255,0.2);padding:1rem 1.5rem;">
        <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:0.5rem;">
          <li><a href="/pictograms/" style="color:rgba(255,255,255,0.8);display:block;padding:0.75rem 0.5rem;font-size:0.875rem;">Substance Database</a></li>
          <li><a href="/inspector/" style="color:rgba(255,255,255,0.8);display:block;padding:0.75rem 0.5rem;font-size:0.875rem;">Inspector</a></li>
          <li><a href="/blog/" style="color:rgba(255,255,255,0.8);display:block;padding:0.75rem 0.5rem;font-size:0.875rem;">Blog</a></li>
          <li><a href="/faq/" style="color:rgba(255,255,255,0.8);display:block;padding:0.75rem 0.5rem;font-size:0.875rem;">FAQ</a></li>
          <li style="margin-top:0.5rem;"><a href="/label-constructor/" style="background:white;color:#062A78;font-weight:700;padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.875rem;display:inline-block;">Build Label →</a></li>
        </ul>
      </div>
    </header>

    <script is:inline>
      (function() {
        function handleResize() {
          var burger = document.getElementById('idx-burger');
          var desktopNav = document.getElementById('desktop-nav');
          if (window.innerWidth < 768) {
            burger.style.display = 'block';
            desktopNav.style.display = 'none';
          } else {
            burger.style.display = 'none';
            desktopNav.style.display = 'flex';
            document.getElementById('idx-mobile-menu').style.display = 'none';
          }
        }
        handleResize();
        window.addEventListener('resize', handleResize);
        document.getElementById('idx-burger').addEventListener('click', function() {
          var menu = document.getElementById('idx-mobile-menu');
          menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
        });
      })();
    </script>

    <section class="hero">
      <div class="hero-inner">
        <p class="hero-eyebrow">GHS / CLP Compliant Tools</p>
        <h1 class="font-heading">GHS Hazard Pictograms — Free SVG Downloads</h1>
        <p class="hero-sub">
          GHS pictogram library, label builder and ADR/DOT inspector for 4,178 classified substances.
        </p>
        <div class="hero-actions">
          <a href="/label-constructor/" class="btn-primary-hero">Build a Label — Free</a>
          <a href="/pictograms/" class="btn-outline-hero">Browse Substances →</a>
          <a href="/inspector/" class="btn-outline-hero">ADR Inspector →</a>
        </div>
      </div>
    </section>

    <div class="stats-bar">
      <div class="stats-inner">
        {
          stats.map((s) => (
            <div class="stat-cell">
              <div class="stat-value">{s.value}</div>
              {s.label ? <div class="stat-label">{s.label}</div> : null}
            </div>
          ))
        }
      </div>
    </div>

    <section class="section">
      <p class="section-label">Reference</p>
      <h2 class="section-title">GHS Hazard Pictograms — GHS01 to GHS09</h2>
      <div class="p-grid">
        {
          pictogramsRows.map((p) => (
            <a href={`/ghs/${p.code.toLowerCase()}/`} class="p-card">
              <div class="p-card-svg">
                {p.svg_content && String(p.svg_content).toLowerCase().includes('<svg') ? (
                  <Fragment set:html={p.svg_content} />
                ) : p.svg_url ? (
                  <img src={p.svg_url} alt="" width="64" height="64" />
                ) : (
                  <span class="p-code">{p.code}</span>
                )}
              </div>
              <span class="p-code">{p.code}</span>
              <span class="p-name">{p.name_en}</span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="section">
      <p class="section-label">Database</p>
      <h2 class="section-title">Search the Substance Database</h2>
      <form class="search-form" method="get" action="/pictograms/">
        <div class="search-wrap">
          <span class="search-icon" aria-hidden="true">⌕</span>
          <input
            type="search"
            name="search"
            placeholder="Search by name or CAS number — e.g. acetone, 67-64-1"
            autocomplete="off"
          />
        </div>
      </form>
    </section>

    <div class="tools-section">
      <div class="tools-inner">
        <p class="section-label">Tools</p>
        <div class="tools-grid" style="margin-top: 1.5rem;">
          {
            tools.map((t) => (
              <div class="tool-card">
                <span class:list={['tool-badge', t.badge === 'NEW' && 'tool-badge--new']}>{t.badge}</span>
                <h3 class="tool-title">{t.title}</h3>
                <p class="tool-desc">{t.description}</p>
                <a href={t.href} class="tool-cta">{t.cta}</a>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <section class="sister">
      <div class="sister-inner">
        <div>
          <h3>Need H-Statements &amp; ATE Calculations?</h3>
          <p>
            Our sister site GHSSymbols.com covers hazard classification, mixture ATE calculator, and storage compatibility
            matrix.
          </p>
        </div>
        <a href="https://ghssymbols.com/" target="_blank" rel="noopener noreferrer" class="btn-sister">Visit GHSSymbols.com →</a>
      </div>
    </section>

    <footer class="site-footer">
      <div class="footer-inner">
