---
export const prerender = true
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, follow" />
    <title>Subscription confirmed — GHS Pictograms</title>
    <style>
      :root {
        --navy: #172554;
        --cta: #f97316;
        --ink: #16224a;
        --muted: #6b7488;
        --success: #1f8a4c;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
        background: var(--navy);
        color: #fff;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
      }
      .card {
        background: #fff;
        color: var(--ink);
        max-width: 480px;
        width: 100%;
        border-radius: 16px;
        padding: 40px 32px;
        text-align: center;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35);
      }
      .badge {
        width: 64px;
        height: 64px;
        margin: 0 auto 20px;
        border-radius: 50%;
        background: #e8f5ee;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .badge svg { width: 32px; height: 32px; }
      h1 { font-size: 24px; margin: 0 0 12px; color: var(--ink); }
      p { font-size: 16px; line-height: 1.6; color: var(--muted); margin: 0 0 12px; }
      .actions { margin-top: 16px; display: flex; flex-direction: column; gap: 12px; }
      .btn {
        display: inline-block;
        text-decoration: none;
        font-weight: 600;
        font-size: 15px;
        padding: 13px 20px;
        border-radius: 10px;
      }
      .btn-primary { background: var(--cta); color: #fff; }
      .btn-secondary { background: #eef1f8; color: var(--ink); }

      /* Welcome gift — the compliance deadline calendar */
      .gift {
        margin-top: 28px;
        padding: 20px;
        border: 1px solid #e4e8f2;
        border-radius: 12px;
        background: #f8faff;
      }
      .gift-label {
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.6px;
        text-transform: uppercase;
        color: var(--cta);
        margin: 0 0 12px;
      }
      .btn-download {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        width: 100%;
        line-height: 1.3;
      }
      .btn-download svg { width: 18px; height: 18px; flex-shrink: 0; }
      .gift-meta {
        display: block;
        margin-top: 10px;
        font-size: 12px;
        color: var(--muted);
        letter-spacing: 0.2px;
      }
    </style>
  </head>
  <body>
    <main class="card">
      <div class="badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="#1f8a4c" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>
      <h1>You're subscribed!</h1>
      <p>Thanks for confirming. You'll now receive GHS / CLP / OSHA compliance updates and regulatory deadline alerts from GHS Pictograms.</p>
      <p>You can unsubscribe at any time using the link at the bottom of any email.</p>

      <div class="gift">
        <p class="gift-label">Your welcome gift is ready</p>
        <a class="btn btn-primary btn-download" href="/downloads/GHS-CLP-OSHA-Compliance-Deadline-Calendar-2026-2029.pdf" download>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
          Download the 2026–2029 Compliance Deadline Calendar
        </a>
        <span class="gift-meta">PDF · GHS · CLP · OSHA deadlines · verified June 2026</span>
      </div>

      <div class="actions">
        <a class="btn btn-secondary" href="/">Back to GHS Pictograms</a>
        <a class="btn btn-secondary" href="/compliance/">Explore the Compliance Hub</a>
      </div>
    </main>
  </body>
</html>
