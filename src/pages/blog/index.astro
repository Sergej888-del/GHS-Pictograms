export const prerender = true;

---
import Layout from '../../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
---

<Layout
  title="GHS Pictograms Blog — Guides, CLP Label Rules and Chemical Safety"
  description="In-depth guides on GHS pictograms, CLP label requirements, and practical tips for creating compliant chemical labels."
  canonical="https://ghspictograms.com/blog/"
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <nav class="text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
      <a href="/" class="text-[#062A78] hover:underline">Home</a>
      <span class="mx-2">→</span>
      <span class="text-gray-700">Blog</span>
    </nav>

    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 tracking-tight" style="font-family: 'Space Grotesk', system-ui, sans-serif">
      GHS Pictograms Blog
    </h1>
    <p class="mt-4 text-gray-700 leading-relaxed text-lg">
      Practical CLP/GHS guides for building compliant labels and understanding hazard pictograms.
    </p>

    <div class="mt-10 grid gap-4">
      {posts.map((post) => (
        <article class="bg-white border border-gray-200 rounded-xl p-5 hover:border-gray-300 transition-colors">
          <p class="text-xs text-gray-500">
            {post.data.pubDate.toISOString().slice(0, 10)}
            {post.data.tags?.length ? <span class="mx-2 text-gray-300">•</span> : null}
            {post.data.tags?.length ? (
              <span class="text-gray-500">{post.data.tags.slice(0, 3).join(', ')}</span>
            ) : null}
          </p>
          <h2 class="mt-2 text-xl font-bold text-gray-900">
            <a href={`/blog/${post.id}/`} class="text-[#062A78] hover:underline">{post.data.title}</a>
          </h2>
          <p class="mt-2 text-gray-700 leading-relaxed">{post.data.description}</p>
          <p class="mt-3 text-sm">
            <a href={`/blog/${post.id}/`} class="text-[#062A78] font-semibold hover:underline">Read article →</a>
          </p>
        </article>
      ))}
    </div>
  </div>
</Layout>

