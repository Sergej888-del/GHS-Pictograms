---
// Chemical Storage Compatibility Matrix — flagship storage tool (v2)
// Static page (astro.config output: 'static'). The interactive island
// (StorageTool) renders the two-column search + verdict UI; hero and
// methodology are static. Verdict data comes from the get_storage_verdict RPC.
export const prerender = true
import Layout from '../../layouts/Layout.astro'
import StorageTool from '../../components/StorageTool'
---
<Layout
  title="Chemical Storage Compatibility Matrix — what can be stored together"
  description="Check chemical storage compatibility by GHS hazard class, chemical reactivity, and ADR transport. See what to never store together, what to keep separate, and each substance's transport class."
  canonical="https://ghspictograms.com/tools/chemical-storage-compatibility/"
>
  <!-- HERO -->
  <section class="bg-gradient-to-br from-[#172554] to-[#1e3a8a] text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-12">
      <nav class="text-sm text-blue-200 mb-3" aria-label="Breadcrumb">
        <a href="/tools/" class="hover:text-white transition-colors">Tools</a>
        <span class="mx-1.5 text-blue-300">/</span>
        <span class="text-blue-100">Storage compatibility</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight" style="font-family:'Space Grotesk',sans-serif;">
        Chemical storage compatibility matrix
      </h1>
      <p class="mt-3 text-lg text-blue-100 max-w-3xl">
        See what can — and can't — be stored together, by GHS hazard class, chemical reactivity, and ADR transport class.
      </p>
    </div>
  </section>

  <!-- TOOL (interactive island) -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <StorageTool client:load />
  </section>

  <!-- HOW IT WORKS -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-14">
    <div class="rounded-xl border border-gray-200 bg-gray-50 p-6 sm:p-8">
      <h2 class="text-xl font-bold text-gray-900" style="font-family:'Space Grotesk',sans-serif;">How this tool works</h2>
      <div class="mt-4 grid grid-cols-1 sm:grid-cols-3 gap-5 text-sm">
        <div>
          <p class="font-semibold text-gray-900">GHS hazard class</p>
          <p class="mt-1 text-gray-600">Each substance is sorted into a storage class from its GHS hazard codes, so incompatible classes can be flagged.</p>
        </div>
        <div>
          <p class="font-semibold text-gray-900">Chemical reactivity</p>
          <p class="mt-1 text-gray-600">Reactivity data identifies pairs that can react dangerously when a spill or leak brings them into contact.</p>
        </div>
        <div>
          <p class="font-semibold text-gray-900">ADR transport</p>
          <p class="mt-1 text-gray-600">Transport data adds the UN number, ADR class, and packing group for moving the substance by road.</p>
        </div>
      </div>
      <p class="mt-6 text-xs text-gray-500 leading-relaxed">
        This tool is a reference aid, not a substitute for a substance's Safety Data Sheet or professional judgment. Always verify storage and handling against SDS sections 7 and 10, and follow local regulations.
      </p>
      <p class="mt-2 text-xs text-gray-400">
        Data sources: GHS/CLP hazard classifications, CAMEO Chemicals (NOAA), ADR 2025 (UNECE).
      </p>
    </div>
  </section>
</Layout>
