---
import Layout from '../../layouts/Layout.astro'

// Flagship interactive tools (own pages)
const flagship = [
  {
    name: 'GHS Label Maker',
    href: '/label-constructor/',
    badge: 'Most popular',
    desc: 'Build print-ready GHS labels sized to your actual container per CLP Annex I — auto-filled pictograms, signal word and H/P statements for 4,000+ substances, your logo, PDF/SVG export. Free, no signup.',
    cta: 'Build a Label →',
  },
  {
    name: 'GHS Pictogram Selector',
    href: '/pictogram-selector/',
    badge: 'Jurisdiction-aware',
    desc: 'Pick hazard classes and categories to get the correct label pictograms, signal word and hazard statements for UN GHS, EU CLP, GB CLP and OSHA HazCom — with CLP Article 26 precedence applied and explained.',
    cta: 'Open the Selector →',
  },
  {
    name: 'GHS vs ADR/DOT Inspector',
    href: '/inspector/',
    badge: 'Transport',
    desc: 'Compare workplace GHS classification with ADR/DOT transport requirements: ADR class, packing group and transport placards for any substance in the database.',
    cta: 'Open the Inspector →',
  },
]

// Classification calculators — each lives on its pictogram page
const calculators = [
  { code: 'GHS01', name: 'Explosive screening (waiver check)', desc: 'The GHS screening step for explosives ahead of UN testing.' },
  { code: 'GHS02', name: 'Flash point → GHS category', desc: 'Classify a flammable liquid from its closed-cup flash point.' },
  { code: 'GHS03', name: 'Oxidizer screening (waiver check)', desc: 'The GHS screening step for oxidizers ahead of UN testing.' },
  { code: 'GHS04', name: 'Critical temperature → gas group', desc: 'Assign the gas-under-pressure group from critical temperature.' },
  { code: 'GHS05', name: 'pH → corrosion trigger', desc: 'Check whether extreme pH triggers skin/eye corrosion classification.' },
  { code: 'GHS06', name: 'LD50 / LC50 → acute toxicity category', desc: 'Assign the acute toxicity category from LD50 or LC50 values.' },
  { code: 'GHS07', name: 'LLNA EC3 → skin-sensitiser sub-category', desc: 'Assign skin-sensitisation sub-category 1A or 1B from LLNA EC3.' },
  { code: 'GHS08', name: 'Viscosity → aspiration hazard', desc: 'Check aspiration hazard for hydrocarbons from kinematic viscosity.' },
  { code: 'GHS09', name: 'Aquatic L(E)C50 → environmental class', desc: 'Classify aquatic hazard from the lowest acute L(E)C50 / EC50.' },
]

const itemList = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Free GHS Tools & Software',
  url: 'https://ghspictograms.com/tools/',
  description: 'Free online GHS compliance tools: label maker, pictogram selector, transport inspector and nine classification calculators built on a CLP substance database.',
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: flagship.length + calculators.length,
    itemListElement: [
      ...flagship.map((t, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: t.name,
        url: `https://ghspictograms.com${t.href}`,
      })),
      ...calculators.map((c, i) => ({
        '@type': 'ListItem',
        position: flagship.length + i + 1,
        name: `${c.code} calculator: ${c.name}`,
        url: `https://ghspictograms.com/ghs/${c.code.toLowerCase()}/`,
      })),
    ],
  },
}
---
<Layout
  title="Free GHS Tools & Software — Label Maker, Calculators, Selector"
  description="11 free online GHS compliance tools: label maker, pictogram selector, 9 classification calculators (flash point, LD50, pH, aquatic toxicity) and a GHS vs ADR/DOT inspector. No signup, no install — built on a 4,000+ substance CLP database."
  canonical="https://ghspictograms.com/tools/"
>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-4">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-3">Free GHS Tools &amp; Software</h1>
    <p class="text-lg text-gray-600 max-w-3xl">
      Every tool on this page is free GHS software that runs in your browser — no signup, no install.
      Build compliant labels, pick the right pictograms by jurisdiction, and run the classification
      calculators, all backed by a database of 4,000+ substances with harmonised CLP classifications.
    </p>
  </section>

  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h2 class="text-xl font-semibold text-gray-900 mb-4">Interactive tools</h2>
    <div class="grid gap-4 md:grid-cols-3">
      {flagship.map((t) => (
        <a href={t.href} class="flex flex-col rounded-xl border border-gray-200 bg-white p-5 hover:border-orange-400 hover:shadow-md transition-all">
          <span class="text-xs font-semibold uppercase tracking-wide text-orange-600 mb-2">{t.badge}</span>
          <h3 class="text-lg font-bold text-gray-900 mb-2">{t.name}</h3>
          <p class="text-sm text-gray-600 leading-relaxed flex-1">{t.desc}</p>
          <span class="mt-4 text-sm font-semibold text-orange-600">{t.cta}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h2 class="text-xl font-semibold text-gray-900 mb-2">GHS classification calculators</h2>
    <p class="text-sm text-gray-600 mb-4 max-w-3xl">
      Nine boundary-tested calculators — one per hazard pictogram. Each lives on its pictogram page
      alongside the hazard explanation, the official SVG download and the full substance list.
    </p>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {calculators.map((c) => (
        <a href={`/ghs/${c.code.toLowerCase()}/`} class="rounded-lg border border-gray-200 bg-white p-4 hover:border-orange-400 hover:shadow-sm transition-all">
          <div class="text-xs font-mono text-gray-400 mb-1">{c.code}</div>
          <div class="font-semibold text-sm text-gray-900 mb-1">{c.name}</div>
          <p class="text-xs text-gray-500 leading-relaxed">{c.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pb-16">
    <div class="rounded-xl bg-gray-50 border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-2">Why free, browser-based GHS tools?</h2>
      <p class="text-sm text-gray-600 leading-relaxed max-w-3xl">
        Most GHS labeling software is desktop-based and licensed per seat. These tools cover the
        everyday tasks — checking a classification boundary, picking pictograms for a jurisdiction,
        printing a correctly sized label — directly in the browser, using harmonised classifications
        from CLP Annex VI. For managing a full SDS library, authoring Safety Data Sheets or running a
        chemical register, see our <a href="/compliance/sds/" class="text-orange-600 font-medium hover:underline">SDS compliance guides</a>.
      </p>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(itemList)} />
</Layout>
