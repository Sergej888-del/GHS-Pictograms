---
import Layout from '../../layouts/Layout.astro'
import LabelConstructorLoader from '../../components/LabelConstructorLoader'
---
<Layout
  title="GHS Label Constructor — Build a compliant label"
  description="Create a CLP-compliant GHS label for any chemical substance. Auto-filled from our database."
  canonical="https://ghspictograms.com/label-constructor/"
>
  <div class="max-w-5xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">GHS Label Constructor</h1>
    <p class="text-gray-600 mb-8">
      Build a CLP-compliant label. Select a substance from the
      <a href="/pictograms/" class="text-[#062A78] underline">pictogram database</a>
      or search below.
    </p>
    <LabelConstructorLoader client:load />
  </div>
</Layout>
