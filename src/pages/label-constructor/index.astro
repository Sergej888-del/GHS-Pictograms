---
// Статическая лендинг-страница конструктора этикеток (без Supabase).
const canonical = 'https://ghspictograms.com/label-constructor/'

const steps = [
  {
    icon: '🔍',
    title: 'Find Substance',
    text: 'Search our 4,178 substance database',
  },
  {
    icon: '📦',
    title: 'Select Container',
    text: 'Choose volume for correct label size (CLP Annex I)',
  },
  {
    icon: '🏢',
    title: 'Add Supplier Info',
    text: 'Company name, address, emergency contact',
  },
  {
    icon: '📋',
    title: 'Review Statements',
    text: 'H-statements, P-statements auto-populated',
  },
  {
    icon: '⬇️',
    title: 'Download PDF',
    text: 'Print-ready label, export in seconds',
  },
]

const popular = [
  { name: 'Acetone', cas: '67-64-1' },
  { name: 'Sulfuric Acid', cas: '7664-93-9' },
  { name: 'Methanol', cas: '67-56-1' },
  { name: 'Toluene', cas: '108-88-3' },
  { name: 'Ethanol', cas: '64-17-5' },
  { name: 'Sodium Hydroxide', cas: '1310-73-2' },
]
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GHS Label Constructor — Build a CLP Label in 5 Steps</title>
    <meta
      name="description"
      content="Find your substance in our database, add supplier details, download a print-ready GHS label PDF. Free, no registration."
    />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <meta property="og:title" content="GHS Label Constructor — 5 Steps" />
    <meta
      property="og:description"
      content="Find your substance, add supplier details, download print-ready PDF. Free, no registration."
    />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />

    <style>
      :root {
        --nav: #062a78;
        --nav-dark: #0a3a8c;
        --accent: #0077b6;
        --body: #ffffff;
        --card: #f8fafc;
        --card-border: #e2e8f0;
        --text: #1e293b;
        --muted: #64748b;
        --font-heading: 'Space Grotesk', system-ui, sans-serif;
        --font-body: 'Inter', system-ui, sans-serif;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: var(--font-body);
        font-size: 16px;
        line-height: 1.6;
        color: var(--text);
        background: var(--body);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .font-heading {
        font-family: var(--font-heading);
      }

      /* Nav (как на главной) */
      .site-nav {
        background: var(--nav);
        color: #fff;
        padding: 0 1.5rem;
        min-height: 64px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .nav-logo {
        font-family: var(--font-heading);
        font-size: 1.125rem;
        letter-spacing: 0.02em;
        white-space: nowrap;
      }

      .nav-logo .logo-ghs {
        font-weight: 500;
      }

      .nav-logo .logo-pictograms {
        font-weight: 700;
      }

      .nav-logo .logo-com {
        font-weight: 400;
        color: rgba(255, 255, 255, 0.65);
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        list-style: none;
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      .nav-links a {
        font-size: 0.875rem;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.88);
        transition: color 0.15s;
      }

      .nav-links a:hover {
        color: #fff;
      }

      .nav-links a.nav-current {
        color: #fff;
        font-weight: 600;
      }

      .nav-links a.nav-external {
        color: rgba(255, 255, 255, 0.95);
      }

      .nav-cta {
        background: var(--accent);
        color: #fff !important;
        padding: 0.45rem 1rem;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.8125rem;
        white-space: nowrap;
        transition: filter 0.15s;
      }

      .nav-cta:hover {
        filter: brightness(1.08);
        color: #fff !important;
      }

      /* Hero */
      .hero {
        background: #062a78;
        color: #fff;
        padding: 3.5rem 1.5rem 3rem;
      }

      .hero-inner {
        max-width: 1120px;
        margin: 0 auto;
      }

      .hero-eyebrow {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.75);
        margin-bottom: 1.25rem;
      }

      .hero-eyebrow::before {
        content: '';
        width: 32px;
        height: 1px;
        background: rgba(255, 255, 255, 0.45);
      }

      .hero h1 {
        font-family: var(--font-heading);
        font-size: clamp(2.25rem, 5vw, 3.25rem);
        font-weight: 700;
        line-height: 1.15;
        letter-spacing: -0.02em;
        margin-bottom: 1rem;
      }

      .hero h1 .hero-line-white {
        color: #fff;
      }

      .hero h1 .hero-accent {
        color: var(--accent);
      }

      .hero-sub {
        font-size: 1.125rem;
        color: rgba(255, 255, 255, 0.85);
        max-width: 36rem;
        line-height: 1.65;
      }

      /* Step 1 — поиск */
      .search-section {
        background: #fff;
        padding: 2.75rem 1.5rem 3rem;
        border-bottom: 1px solid var(--card-border);
      }

      .search-inner {
        max-width: 720px;
        margin: 0 auto;
      }

      .search-section h2 {
        font-family: var(--font-heading);
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 1.5rem;
        letter-spacing: -0.02em;
      }

      .lc-form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }

      @media (min-width: 640px) {
        .lc-form {
          flex-direction: row;
          align-items: stretch;
          gap: 0.75rem;
        }
      }

      .lc-input {
        flex: 1;
        font-family: var(--font-body);
        font-size: 1.0625rem;
        padding: 1rem 1.25rem;
        border: 2px solid var(--card-border);
        border-radius: 10px;
        color: var(--text);
        outline: none;
        transition: border-color 0.15s;
      }

      .lc-input:focus {
        border-color: var(--nav);
      }

      .lc-input::placeholder {
        color: var(--muted);
      }

      .lc-submit {
        font-family: var(--font-body);
        font-size: 1rem;
        font-weight: 600;
        padding: 1rem 1.5rem;
        background: var(--accent);
        color: #fff;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        white-space: nowrap;
        transition: filter 0.15s;
      }

      .lc-submit:hover {
        filter: brightness(1.06);
      }

      .try-links {
        margin-top: 1.25rem;
        font-size: 0.9375rem;
        color: var(--muted);
      }

      .try-links a {
        color: var(--nav);
        font-weight: 600;
        text-decoration: underline;
        text-underline-offset: 2px;
      }

      .try-links a:hover {
        color: var(--accent);
      }

      /* 5 шагов */
      .steps-section {
        background: #f8fafc;
        padding: 3rem 1.5rem;
      }

      .steps-inner {
        max-width: 1120px;
        margin: 0 auto;
      }

      .steps-grid {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 1rem;
      }

      .step-card {
        background: #fff;
        border: 1px solid var(--card-border);
        border-radius: 10px;
        padding: 1.25rem 1rem;
        text-align: center;
      }

      .step-num {
        font-family: var(--font-heading);
        font-size: 1.5rem;
        font-weight: 700;
        color: #0077b6;
        line-height: 1;
        margin-bottom: 0.5rem;
      }

      .step-icon {
        font-size: 1.75rem;
        line-height: 1;
        margin-bottom: 0.75rem;
      }

      .step-card h3 {
        font-family: var(--font-heading);
        font-size: 0.9375rem;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 0.35rem;
      }

      .step-card p {
        font-size: 0.8125rem;
        color: var(--muted);
        line-height: 1.5;
      }

      /* BS5609 */
      .bs-wrap {
        padding: 2rem 1.5rem;
        background: #fff;
      }

      .bs-box {
        max-width: 1120px;
        margin: 0 auto;
        background: #fef3c7;
        border: 1px solid #f59e0b;
        border-radius: 10px;
        padding: 1.25rem 1.5rem;
      }

      .bs-box p {
        font-size: 0.9375rem;
        color: #78350f;
        line-height: 1.6;
      }

      .bs-box a {
        display: inline-block;
        margin-top: 0.75rem;
        font-weight: 600;
        color: var(--nav);
        text-decoration: underline;
        text-underline-offset: 2px;
      }

      .bs-box a:hover {
        color: var(--accent);
      }

      /* Popular */
      .popular-section {
        background: #fff;
        padding: 3rem 1.5rem 3.5rem;
      }

      .popular-inner {
        max-width: 1120px;
        margin: 0 auto;
      }

      .popular-section h2 {
        font-family: var(--font-heading);
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 1.5rem;
        letter-spacing: -0.02em;
      }

      .popular-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
      }

      .pop-card {
        display: block;
        border: 1px solid var(--card-border);
        border-radius: 10px;
        padding: 1.25rem 1.15rem;
        transition:
          border-color 0.2s,
          box-shadow 0.2s;
      }

      .pop-card:hover {
        border-color: var(--accent);
        box-shadow: 0 4px 14px rgba(6, 42, 120, 0.08);
      }

      .pop-card .pop-name {
        font-family: var(--font-heading);
        font-weight: 700;
        font-size: 1.0625rem;
        color: var(--nav);
        display: block;
      }

      .pop-card .pop-cas {
        font-size: 0.875rem;
        color: var(--muted);
        margin-top: 0.35rem;
        display: block;
      }

      /* Footer (как на главной) */
      .site-footer {
        background: var(--nav);
        color: rgba(255, 255, 255, 0.85);
        padding: 2rem 1.5rem;
      }

      .footer-inner {
        max-width: 1120px;
        margin: 0 auto;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .footer-logo {
        font-family: var(--font-heading);
        font-size: 0.9375rem;
      }

      .footer-logo .logo-ghs {
        font-weight: 500;
        color: #fff;
      }

      .footer-logo .logo-pictograms {
        font-weight: 700;
        color: #fff;
      }

      .footer-logo .logo-com {
        font-weight: 400;
        color: rgba(255, 255, 255, 0.6);
      }

      .footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 1.25rem;
        list-style: none;
      }

      .footer-links a {
        font-size: 0.8125rem;
        color: rgba(255, 255, 255, 0.8);
      }

      .footer-links a:hover {
        color: #fff;
      }

      .footer-copy {
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.55);
        width: 100%;
        flex-basis: 100%;
      }

      @media (max-width: 1024px) {
        .steps-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

      @media (max-width: 768px) {
        .nav-links {
          display: none;
        }

        .steps-grid {
          grid-template-columns: 1fr;
        }

        .popular-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <nav class="site-nav" aria-label="Main">
      <a href="/" class="nav-logo">
        <span class="logo-ghs">GHS</span><span class="logo-pictograms">PICTOGRAMS</span><span class="logo-com">.COM</span>
      </a>
      <ul class="nav-links">
        <li><a href="/label-constructor/" class="nav-current">Label Constructor</a></li>
        <li><a href="/pictograms/">Substance Database</a></li>
        <li>
          <a href="https://ghssymbols.com/" target="_blank" rel="noopener noreferrer" class="nav-external">GHS Symbols ↗</a>
        </li>
        <li><a href="/label-constructor/" class="nav-cta">Build Label →</a></li>
      </ul>
    </nav>

    <section class="hero" aria-labelledby="lc-hero-heading">
      <div class="hero-inner">
        <p class="hero-eyebrow">GHS / CLP Label Builder</p>
        <h1 id="lc-hero-heading" class="font-heading">
          <span class="hero-line-white">Build a GHS Label</span><br />
          <span class="hero-accent">in 5 Steps</span>
        </h1>
        <p class="hero-sub">
          Find your substance, add supplier details, download print-ready PDF. Free, no registration.
        </p>
      </div>
    </section>

    <section class="search-section" aria-labelledby="step1-heading">
      <div class="search-inner">
        <h2 id="step1-heading">Step 1 — Find Your Substance</h2>
        <form class="lc-form" action="/pictograms/" method="get">
          <input
            type="search"
            name="search"
            class="lc-input"
            placeholder="Enter substance name or CAS number..."
            autocomplete="off"
            aria-label="Substance name or CAS"
          />
          <button type="submit" class="lc-submit">Find Substance →</button>
        </form>
        <p class="try-links">
          Try:
          <a href="/pictograms/67-64-1/">acetone</a>
          ·
          <a href="/pictograms/7664-93-9/">sulfuric acid</a>
          ·
          <a href="/pictograms/67-56-1/">methanol</a>
          ·
          <a href="/pictograms/108-88-3/">toluene</a>
        </p>
      </div>
    </section>

    <section class="steps-section" aria-label="Label builder steps">
      <div class="steps-inner">
        <div class="steps-grid">
          {
            steps.map((s, i) => (
              <div class="step-card">
                <div class="step-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</div>
                <div class="step-icon" aria-hidden="true">{s.icon}</div>
                <h3>{s.title}</h3>
                <p>{s.text}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <div class="bs-wrap">
      <div id="bs5609" class="bs-box" role="note">
        <p>
          ⚠️ For transport and marine shipping labels, BS5609 certification requires specific materials and printers.
          Office printing does not meet IMDG requirements.
        </p>
        <a href="/label-constructor/">Learn about BS5609 →</a>
      </div>
    </div>

    <section class="popular-section" aria-labelledby="popular-heading">
      <div class="popular-inner">
        <h2 id="popular-heading">Popular Substances</h2>
        <div class="popular-grid">
          {
            popular.map((p) => (
              <a href={`/pictograms/${p.cas}/`} class="pop-card">
                <span class="pop-name">{p.name}</span>
                <span class="pop-cas">CAS {p.cas}</span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <footer class="site-footer">
      <div class="footer-inner">
        <span class="footer-logo">
          <span class="logo-ghs">GHS</span><span class="logo-pictograms">PICTOGRAMS</span><span class="logo-com">.COM</span>
        </span>
        <ul class="footer-links">
          <li><a href="/label-constructor/">Label Constructor</a></li>
          <li><a href="/pictograms/">Substance Database</a></li>
          <li><a href="https://ghssymbols.com/">GHSSymbols.com</a></li>
        </ul>
        <span class="footer-copy">Data source: ECHA CLP Annex VI · For reference only</span>
      </div>
    </footer>
  </body>
</html>
