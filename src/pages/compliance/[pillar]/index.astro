---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export const prerender = true;

// Pillar metadata: colors, icons, descriptions
// (Duplicated from compliance/index.astro — could be extracted to src/lib/pillarMeta.ts later)
const pillarMeta = {
  'un-ghs': {
    label: 'UN GHS',
    fullName: 'United Nations Globally Harmonized System',
    description:
      'The international foundation for chemical hazard classification and communication. Adopted by 80+ countries, the UN GHS provides the standardized framework for hazard classes, label elements, pictograms, and the 16-section Safety Data Sheet format.',
    short: 'International foundation for chemical hazard classification.',
    heroGradient: 'from-slate-900 via-blue-900 to-indigo-900',
    heroBgAccentA: 'bg-blue-400',
    heroBgAccentB: 'bg-indigo-400',
    heroOverline: 'text-blue-300',
    heroBody: 'text-blue-100',
    heroPillBg: 'bg-white/10',
    heroPillText: 'text-blue-200',
    iconBg: 'bg-blue-600',
    cardHover: 'hover:border-blue-400 hover:text-blue-700',
    accentText: 'text-blue-700',
    accentLight: 'text-blue-600',
    iconPath:
      'M12 21a9 9 0 100-18 9 9 0 000 18zM3.6 9h16.8M3.6 15h16.8M11.5 3a17 17 0 000 18M12.5 3a17 17 0 010 18',
  },
  'osha-hcs': {
    label: 'OSHA HCS',
    fullName: 'OSHA Hazard Communication Standard',
    description:
      'The US workplace chemical safety regulation aligned with GHS. OSHA HCS at 29 CFR 1910.1200 governs hazard classification, labels, and Safety Data Sheets for hazardous chemicals in American workplaces. Recent updates include the HCS 2024 final rule with phased compliance through 2028.',
    short: 'US workplace chemical safety regulation aligning with GHS.',
    heroGradient: 'from-slate-900 via-red-900 to-orange-900',
    heroBgAccentA: 'bg-red-400',
    heroBgAccentB: 'bg-orange-400',
    heroOverline: 'text-red-300',
    heroBody: 'text-red-100',
    heroPillBg: 'bg-white/10',
    heroPillText: 'text-red-200',
    iconBg: 'bg-red-600',
    cardHover: 'hover:border-red-400 hover:text-red-700',
    accentText: 'text-red-700',
    accentLight: 'text-red-600',
    iconPath: 'M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  clp: {
    label: 'CLP',
    fullName: 'EU Classification, Labelling and Packaging Regulation',
    description:
      'European Regulation 1272/2008 implements GHS for chemicals placed on the EU market. CLP covers hazard classification, labelling, packaging requirements, and Annex VI harmonised classifications. Regular Adaptations to Technical Progress (ATPs) keep the regulation aligned with the latest scientific evidence.',
    short: 'EU regulation 1272/2008 implementing GHS for the European market.',
    heroGradient: 'from-slate-900 via-purple-900 to-violet-900',
    heroBgAccentA: 'bg-purple-400',
    heroBgAccentB: 'bg-violet-400',
    heroOverline: 'text-purple-300',
    heroBody: 'text-purple-100',
    heroPillBg: 'bg-white/10',
    heroPillText: 'text-purple-200',
    iconBg: 'bg-purple-600',
    cardHover: 'hover:border-purple-400 hover:text-purple-700',
    accentText: 'text-purple-700',
    accentLight: 'text-purple-600',
    iconPath: 'M12 21V8m0 0l-4 4m4-4l4 4M4 4h16M4 20h16M6 8v9m12-9v9',
  },
  sds: {
    label: 'SDS',
    fullName: 'Safety Data Sheets',
    description:
      'The standardized 16-section document format for communicating chemical hazards, safe handling procedures, and regulatory status. SDS authoring is governed by REACH Annex II in the EU (Regulation (EU) 2020/878) and OSHA HCS Appendix D in the US. The format is universal worldwide thanks to UN GHS Annex 4 alignment.',
    short: '16-section document format communicating chemical hazards.',
    heroGradient: 'from-slate-900 via-emerald-900 to-teal-900',
    heroBgAccentA: 'bg-emerald-400',
    heroBgAccentB: 'bg-teal-400',
    heroOverline: 'text-emerald-300',
    heroBody: 'text-emerald-100',
    heroPillBg: 'bg-white/10',
    heroPillText: 'text-emerald-200',
    iconBg: 'bg-emerald-600',
    cardHover: 'hover:border-emerald-400 hover:text-emerald-700',
    accentText: 'text-emerald-700',
    accentLight: 'text-emerald-600',
    iconPath:
      'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  },
} as const;

type PillarSlug = keyof typeof pillarMeta;

export async function getStaticPaths() {
  // getStaticPaths runs in isolated scope — cannot reference outer pillarOrder.
  // List duplicated with outer pillarOrder below (template scope).
  return [
    { params: { pillar: 'un-ghs' } },
    { params: { pillar: 'osha-hcs' } },
    { params: { pillar: 'clp' } },
    { params: { pillar: 'sds' } },
  ];
}

const pillarOrder: readonly PillarSlug[] = ['un-ghs', 'osha-hcs', 'clp', 'sds'];

const { pillar } = Astro.params;
const pillarSlug = pillar as PillarSlug;
const meta = pillarMeta[pillarSlug];

if (!meta) {
  throw new Error(`Unknown pillar: ${pillar}`);
}

// Cluster articles for this pillar (excludes pillar overview MDX)
const allArticles = await getCollection(
  'compliance',
  ({ data }) => !data.draft && data.pillar === pillarSlug && data.type !== 'pillar'
);

// Sort: newest → oldest
const articles = allArticles.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

// Pillar overview MDX (if exists) — long-form content for this pillar
const pillarArticle = (
  await getCollection(
    'compliance',
    ({ data }) => !data.draft && data.pillar === pillarSlug && data.type === 'pillar'
  )
)[0];

const PillarContent = pillarArticle ? (await render(pillarArticle)).Content : null;

// Date formatting helper
function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

// Badge mapping for article type
function articleTypeBadge(type: string): { label: string; bg: string; color: string } {
  const map: Record<string, { label: string; bg: string; color: string }> = {
    listicle: { label: 'Reference', bg: 'bg-amber-100', color: 'text-amber-800' },
    'event-driven': { label: 'Update', bg: 'bg-rose-100', color: 'text-rose-800' },
    evergreen: { label: 'Evergreen', bg: 'bg-blue-100', color: 'text-blue-800' },
    'deep-dive': { label: 'Deep Dive', bg: 'bg-indigo-100', color: 'text-indigo-800' },
    comparison: { label: 'Comparison', bg: 'bg-emerald-100', color: 'text-emerald-800' },
    'how-to': { label: 'How-to', bg: 'bg-teal-100', color: 'text-teal-800' },
    cluster: { label: 'Article', bg: 'bg-slate-100', color: 'text-slate-700' },
  };
  return map[type] ?? { label: type, bg: 'bg-slate-100', color: 'text-slate-700' };
}

// Other pillars for "Explore other pillars" block
const otherPillars = pillarOrder.filter((p) => p !== pillarSlug);

// SEO title and description — pillar MDX overrides defaults
const pageTitle = pillarArticle?.data.title ?? `${meta.label} — Compliance Hub`;
const pageDescription = pillarArticle?.data.description ?? meta.short;

// JSON-LD: BreadcrumbList (always emitted for pillar pages)
const SITE = 'https://ghspictograms.com';
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Compliance Hub',
      item: `${SITE}/compliance/`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: meta.label,
      item: `${SITE}/compliance/${pillarSlug}/`,
    },
  ],
};

// JSON-LD: Article (only emitted when pillar MDX exists)
const pillarPageUrl = `${SITE}/compliance/${pillarSlug}/`;
const articleSchema = pillarArticle
  ? {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: pillarArticle.data.title,
      description: pillarArticle.data.description,
      datePublished: pillarArticle.data.pubDate.toISOString(),
      dateModified: (
        pillarArticle.data.updatedDate ?? pillarArticle.data.pubDate
      ).toISOString(),
      author: {
        '@type': 'Organization',
        name: 'GHS Pictograms',
        url: 'https://ghspictograms.com',
      },
      publisher: {
        '@type': 'Organization',
        name: 'GHS Pictograms',
        url: 'https://ghspictograms.com',
        logo: {
          '@type': 'ImageObject',
          url: 'https://ghspictograms.com/favicon.svg',
        },
      },
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': pillarPageUrl,
      },
    }
  : null;
---

<Layout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
    {articleSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    )}
  </Fragment>

  <!-- ============================================================ -->
  <!-- BREADCRUMB BAR -->
  <!-- ============================================================ -->
  <nav class="bg-slate-50 border-b border-slate-200" aria-label="Breadcrumb">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3">
      <ol class="flex items-center gap-2 text-sm text-slate-600 flex-wrap">
        <li>
          <a href="/compliance/" class="hover:text-blue-700 transition-colors font-medium">
            Compliance Hub
          </a>
        </li>
        <li class="text-slate-400" aria-hidden="true">›</li>
        <li class="font-semibold text-slate-900" aria-current="page">
          {meta.label}
        </li>
      </ol>
    </div>
  </nav>

  <!-- ============================================================ -->
  <!-- HERO -->
  <!-- ============================================================ -->
  <section class={`relative overflow-hidden bg-gradient-to-br ${meta.heroGradient} text-white`}>
    <!-- Decorative blur pattern -->
    <div class="absolute inset-0 opacity-10">
      <div class={`absolute top-0 left-0 w-96 h-96 ${meta.heroBgAccentA} rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2`}></div>
      <div class={`absolute bottom-0 right-0 w-96 h-96 ${meta.heroBgAccentB} rounded-full blur-3xl translate-x-1/2 translate-y-1/2`}></div>
    </div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-14 sm:py-20">
      <div class="flex items-start gap-5 mb-6">
        <div class={`shrink-0 inline-flex items-center justify-center w-14 h-14 sm:w-16 sm:h-16 rounded-2xl ${meta.iconBg} shadow-lg`}>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 sm:w-8 sm:h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d={meta.iconPath} />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class={`text-xs sm:text-sm font-semibold uppercase tracking-widest ${meta.heroOverline} mb-2`}>
            Regulatory Pillar
          </p>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight leading-tight mb-2">
            {pillarArticle?.data.title ?? meta.label}
          </h1>
          {!pillarArticle && (
            <p class={`text-base sm:text-lg font-medium ${meta.heroBody}`}>
              {meta.fullName}
            </p>
          )}
        </div>
      </div>

      <p class={`text-base sm:text-lg ${meta.heroBody} leading-relaxed max-w-3xl mb-6`}>
        {pillarArticle?.data.description ?? meta.description}
      </p>

      <div class="flex flex-wrap items-center gap-3 text-sm">
        <span class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full ${meta.heroPillBg} backdrop-blur-sm ${meta.heroPillText}`}>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          {articles.length} {articles.length === 1 ? 'article' : 'articles'}
        </span>
        {pillarArticle?.data.updatedDate && (
          <span class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full ${meta.heroPillBg} backdrop-blur-sm ${meta.heroPillText}`}>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Updated {formatDate(pillarArticle.data.updatedDate)}
          </span>
        )}
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- PILLAR CONTENT (rendered only when pillar MDX exists) -->
  <!-- ============================================================ -->
  {PillarContent && (
    <section class="bg-white border-b border-slate-200">
      <article class="max-w-4xl mx-auto px-4 sm:px-6 py-10 sm:py-14">
        <div class="article-content">
          <PillarContent />
        </div>
      </article>
    </section>
  )}

  <!-- ============================================================ -->
  <!-- ARTICLES LIST -->
  <!-- ============================================================ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-14">
    {articles.length > 0 ? (
      <>
        <div class="mb-10">
          <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight mb-2">
            All Articles
          </h2>
          <p class="text-slate-600">
            Sorted by publication date — most recent first.
          </p>
        </div>

        <div class="space-y-5">
          {articles.map((article) => {
            const badge = articleTypeBadge(article.data.type);
            return (
              <a
                href={`/compliance/${article.data.pillar}/${article.data.slug}/`}
                class={`group block bg-white rounded-xl border border-slate-200 ${meta.cardHover} p-6 sm:p-7 transition-all duration-200 hover:shadow-md`}
              >
                <div class="flex items-start gap-3 mb-3 flex-wrap">
                  <span class={`inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold ${badge.bg} ${badge.color}`}>
                    {badge.label}
                  </span>
                  <time class="text-xs text-slate-500 self-center" datetime={article.data.pubDate.toISOString()}>
                    {formatDate(article.data.pubDate)}
                  </time>
                </div>
                <h3 class={`text-xl sm:text-2xl font-bold text-slate-900 leading-snug tracking-tight mb-2 transition-colors`}>
                  {article.data.title}
                </h3>
                <p class="text-slate-600 leading-relaxed mb-4">
                  {article.data.description}
                </p>
                <div class="flex items-center justify-between">
                  <span class={`inline-flex items-center text-sm font-semibold ${meta.accentLight} group-hover:translate-x-1 transition-transform`}>
                    Read article
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      </>
    ) : (
      <!-- Empty state -->
      <div class="text-center py-16 bg-slate-50 rounded-2xl border border-dashed border-slate-300">
        <div class={`inline-flex items-center justify-center w-16 h-16 rounded-2xl ${meta.iconBg} mb-4 opacity-30`}>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d={meta.iconPath} />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-slate-900 mb-2">
          Articles coming soon
        </h3>
        <p class="text-slate-600 max-w-md mx-auto mb-6">
          Deep-dive content for the {meta.label} pillar is in editorial pipeline. Check back regularly or explore other pillars.
        </p>
        <a href="/compliance/" class="inline-flex items-center px-5 py-2.5 rounded-lg bg-slate-900 text-white font-semibold hover:bg-slate-800 transition-colors">
          Back to Compliance Hub
        </a>
      </div>
    )}
  </section>

  <!-- ============================================================ -->
  <!-- OTHER PILLARS -->
  <!-- ============================================================ -->
  <section class="bg-slate-50 border-t border-slate-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14">
      <div class="mb-8">
        <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight mb-2">
          Explore Other Pillars
        </h2>
        <p class="text-slate-600">
          Continue your tour of the Compliance Hub.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {otherPillars.map((slug) => {
          const otherMeta = pillarMeta[slug];
          return (
            <a
              href={`/compliance/${slug}/`}
              class="group block bg-white rounded-xl border border-slate-200 hover:border-blue-400 p-5 transition-all duration-200 hover:shadow-md hover:-translate-y-0.5"
            >
              <div class="flex items-center gap-3 mb-2">
                <div class={`shrink-0 inline-flex items-center justify-center w-10 h-10 rounded-lg ${otherMeta.iconBg}`}>
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d={otherMeta.iconPath} />
                  </svg>
                </div>
                <h3 class={`text-lg font-bold ${otherMeta.accentText}`}>
                  {otherMeta.label}
                </h3>
              </div>
              <p class="text-sm text-slate-600 leading-relaxed mb-3">
                {otherMeta.short}
              </p>
              <span class={`inline-flex items-center text-sm font-semibold ${otherMeta.accentLight} group-hover:translate-x-1 transition-transform`}>
                Explore
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              </span>
            </a>
          );
        })}
      </div>

      <div class="mt-8 text-center">
        <a href="/compliance/" class="inline-flex items-center px-5 py-2.5 rounded-lg border-2 border-slate-300 text-slate-700 font-semibold hover:border-slate-900 hover:text-slate-900 transition-colors">
          ← Back to Compliance Hub
        </a>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  /* Anchor scroll offset — headings land below the page top, not hidden under nav */
  .article-content :is(h1, h2, h3, h4, h5, h6) {
    scroll-margin-top: 5rem;
  }

  /* H2 — major sections */
  .article-content h2 {
    font-size: 1.875rem;
    line-height: 2.25rem;
    font-weight: 700;
    color: #0f172a;
    margin-top: 3.5rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #e2e8f0;
    letter-spacing: -0.01em;
  }

  /* H3 — subsections */
  .article-content h3 {
    font-size: 1.5rem;
    line-height: 2rem;
    font-weight: 700;
    color: #1e293b;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-left: 0.875rem;
    border-left: 4px solid #2563eb;
  }

  /* H4 — sub-subsections */
  .article-content h4 {
    font-size: 1.125rem;
    line-height: 1.75rem;
    font-weight: 600;
    color: #334155;
    margin-top: 1.75rem;
    margin-bottom: 0.625rem;
  }

  /* Body text */
  .article-content p {
    color: #334155;
    line-height: 1.75;
    margin-bottom: 1.125rem;
    font-size: 1.0625rem;
  }

  /* Strong-emphasis labels */
  .article-content p strong,
  .article-content li strong {
    color: #0f172a;
    font-weight: 600;
  }

  /* Lists */
  .article-content ul,
  .article-content ol {
    margin: 1rem 0 1.5rem 0;
    padding-left: 1.5rem;
    color: #334155;
  }
  .article-content li {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }

  /* Links */
  .article-content a {
    color: #2563eb;
    text-decoration: underline;
    text-decoration-color: #93c5fd;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    transition: color 0.15s, text-decoration-color 0.15s;
  }
  .article-content a:hover {
    color: #1d4ed8;
    text-decoration-color: #2563eb;
  }

  /* Tables */
  .article-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.9375rem;
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    overflow: hidden;
  }
  .article-content thead {
    background: #f1f5f9;
  }
  .article-content th {
    text-align: left;
    padding: 0.875rem 1rem;
    font-weight: 600;
    color: #0f172a;
    border-bottom: 2px solid #cbd5e1;
  }
  .article-content td {
    padding: 0.875rem 1rem;
    border-bottom: 1px solid #e2e8f0;
    color: #334155;
    vertical-align: top;
  }
  .article-content tbody tr:hover {
    background: #f8fafc;
  }
  .article-content tbody tr:last-child td {
    border-bottom: none;
  }

  /* Blockquotes */
  .article-content blockquote {
    border-left: 4px solid #2563eb;
    background: #f8fafc;
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: #475569;
    border-radius: 0 0.375rem 0.375rem 0;
  }

  /* Code */
  .article-content code {
    background: #f1f5f9;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
    color: #0f172a;
  }

  /* Mobile adjustments */
  @media (max-width: 640px) {
    .article-content h2 {
      font-size: 1.5rem;
      line-height: 2rem;
    }
    .article-content h3 {
      font-size: 1.25rem;
      line-height: 1.75rem;
    }
    .article-content p {
      font-size: 1rem;
    }
  }
</style>
