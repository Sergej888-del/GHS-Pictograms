---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

// Все опубликованные статьи compliance hub
const allArticles = await getCollection('compliance', ({ data }) => !data.draft && data.type !== 'pillar');

// Сортировка: новые → старые
const sortedArticles = allArticles.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

// Featured anchor: Wave 1 #1 (UN GHS Implementation by Country)
const featuredArticle = sortedArticles.find(
  (a) => a.data.slug === 'un-ghs-implementation-by-country'
) ?? sortedArticles[0];

// Все статьи кроме featured (для Recent grid)
const recentArticles = sortedArticles.filter(
  (a) => a.data.slug !== featuredArticle?.data.slug
);

// Метаданные пилларов: цвета, иконки, описания, счётчики
const pillarMeta: Record<
  string,
  {
    label: string;
    fullName: string;
    description: string;
    /** Тэйлвинд-классы для карточки (статические — не template literals) */
    cardBg: string;
    cardBorder: string;
    iconBg: string;
    iconColor: string;
    pillBg: string;
    pillText: string;
    accentText: string;
    arrowHover: string;
    /** Inline SVG path (Heroicons outline style) */
    iconPath: string;
  }
> = {
  'un-ghs': {
    label: 'UN GHS',
    fullName: 'United Nations Globally Harmonized System',
    description:
      'The international foundation for chemical hazard classification and communication, adopted by 80+ countries.',
    cardBg: 'bg-gradient-to-br from-blue-50 to-indigo-50',
    cardBorder: 'border-blue-200 hover:border-blue-400',
    iconBg: 'bg-blue-600',
    iconColor: 'text-white',
    pillBg: 'bg-blue-100',
    pillText: 'text-blue-800',
    accentText: 'text-blue-700',
    arrowHover: 'group-hover:translate-x-1',
    iconPath:
      'M12 21a9 9 0 100-18 9 9 0 000 18zM3.6 9h16.8M3.6 15h16.8M11.5 3a17 17 0 000 18M12.5 3a17 17 0 010 18',
  },
  'osha-hcs': {
    label: 'OSHA HCS',
    fullName: 'OSHA Hazard Communication Standard',
    description:
      'US workplace chemical safety regulation aligning with GHS — governs labels and SDS for hazardous chemicals in the United States.',
    cardBg: 'bg-gradient-to-br from-red-50 to-orange-50',
    cardBorder: 'border-red-200 hover:border-red-400',
    iconBg: 'bg-red-600',
    iconColor: 'text-white',
    pillBg: 'bg-red-100',
    pillText: 'text-red-800',
    accentText: 'text-red-700',
    arrowHover: 'group-hover:translate-x-1',
    iconPath: 'M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  clp: {
    label: 'CLP',
    fullName: 'EU Classification, Labelling and Packaging',
    description:
      'European Regulation 1272/2008 implementing GHS for chemicals placed on the EU market — covers Annex VI harmonised classifications and ATP updates.',
    cardBg: 'bg-gradient-to-br from-purple-50 to-violet-50',
    cardBorder: 'border-purple-200 hover:border-purple-400',
    iconBg: 'bg-purple-600',
    iconColor: 'text-white',
    pillBg: 'bg-purple-100',
    pillText: 'text-purple-800',
    accentText: 'text-purple-700',
    arrowHover: 'group-hover:translate-x-1',
    iconPath:
      'M12 21V8m0 0l-4 4m4-4l4 4M4 4h16M4 20h16M6 8v9m12-9v9',
  },
  sds: {
    label: 'SDS',
    fullName: 'Safety Data Sheets',
    description:
      'The 16-section document format communicating chemical hazards, safe handling and regulatory status — governed by REACH Annex II in the EU and OSHA HCS Appendix D in the US.',
    cardBg: 'bg-gradient-to-br from-emerald-50 to-teal-50',
    cardBorder: 'border-emerald-200 hover:border-emerald-400',
    iconBg: 'bg-emerald-600',
    iconColor: 'text-white',
    pillBg: 'bg-emerald-100',
    pillText: 'text-emerald-800',
    accentText: 'text-emerald-700',
    arrowHover: 'group-hover:translate-x-1',
    iconPath:
      'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  },
};

// Порядок отображения пилларов
const pillarOrder = ['un-ghs', 'osha-hcs', 'clp', 'sds'] as const;

// Подсчёт статей в каждом пилларе
const pillarCounts: Record<string, number> = {};
for (const article of allArticles) {
  pillarCounts[article.data.pillar] = (pillarCounts[article.data.pillar] ?? 0) + 1;
}

// Helper для форматирования даты
function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const pageTitle = 'Compliance Hub';
const pageDescription =
  'Chemical safety regulations explained — UN GHS, OSHA HCS, CLP, SDS. Authoritative articles with citations, timelines and regional comparisons.';
---

<Layout title={pageTitle} description={pageDescription}>
  <!-- ============================================================ -->
  <!-- HERO -->
  <!-- ============================================================ -->
  <section class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-blue-900 to-indigo-900 text-white">
    <!-- Декоративный pattern на фоне -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 left-0 w-96 h-96 bg-blue-400 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
      <div class="absolute bottom-0 right-0 w-96 h-96 bg-indigo-400 rounded-full blur-3xl translate-x-1/2 translate-y-1/2"></div>
    </div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
      <p class="text-xs sm:text-sm font-semibold uppercase tracking-widest text-blue-300 mb-4">
        GHS Pictograms · Editorial
      </p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-tight mb-6">
        Compliance Hub
      </h1>
      <p class="text-lg sm:text-xl text-blue-100 leading-relaxed max-w-3xl mb-8">
        Chemical safety regulations, explained. Deep-dive articles on UN GHS, OSHA HCS, EU CLP, and SDS authoring — with citations, timelines and regional comparisons for compliance professionals.
      </p>
      <div class="flex flex-wrap items-center gap-3 text-sm text-blue-200">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-white/10 backdrop-blur-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          {allArticles.length} articles
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-white/10 backdrop-blur-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/></svg>
          {pillarOrder.length} regulatory pillars
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-white/10 backdrop-blur-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Updated continuously
        </span>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- PILLAR GRID -->
  <!-- ============================================================ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
    <div class="mb-10">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight mb-2">
        Regulatory Pillars
      </h2>
      <p class="text-slate-600 max-w-2xl">
        Each pillar covers one major regulatory framework. Click through for the full article library.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {pillarOrder.map((slug) => {
        const meta = pillarMeta[slug];
        const count = pillarCounts[slug] ?? 0;
        return (
          <a
            href={`/compliance/${slug}/`}
            class={`group block rounded-2xl border-2 ${meta.cardBorder} ${meta.cardBg} p-6 transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5`}
          >
            <div class={`inline-flex items-center justify-center w-12 h-12 rounded-xl ${meta.iconBg} mb-4 shadow-sm`}>
              <svg xmlns="http://www.w3.org/2000/svg" class={`w-6 h-6 ${meta.iconColor}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d={meta.iconPath} />
              </svg>
            </div>
            <h3 class={`text-xl font-bold ${meta.accentText} mb-1`}>
              {meta.label}
            </h3>
            <p class="text-sm font-medium text-slate-700 mb-3">
              {meta.fullName}
            </p>
            <p class="text-sm text-slate-600 leading-relaxed mb-4">
              {meta.description}
            </p>
            <div class="flex items-center justify-between">
              <span class={`inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold ${meta.pillBg} ${meta.pillText}`}>
                {count} {count === 1 ? 'article' : 'articles'}
              </span>
              <span class={`inline-flex items-center text-sm font-semibold ${meta.accentText} transition-transform ${meta.arrowHover}`}>
                Explore
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- FEATURED ARTICLE -->
  <!-- ============================================================ -->
  {featuredArticle && (
    <section class="bg-slate-50 border-y border-slate-200">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
        <div class="mb-8">
          <p class="text-xs font-semibold uppercase tracking-widest text-amber-600 mb-2 flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l2.4 7.4H22l-6 4.4 2.3 7.2L12 16.5 5.7 21l2.3-7.2-6-4.4h7.6z"/></svg>
            Featured Article
          </p>
          <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight">
            Start Here
          </h2>
        </div>

        <a
          href={`/compliance/${featuredArticle.data.pillar}/${featuredArticle.data.slug}/`}
          class="group block bg-white rounded-2xl border-2 border-slate-200 hover:border-blue-400 transition-all duration-200 overflow-hidden hover:shadow-xl"
        >
          <div class="grid md:grid-cols-5 gap-0">
            <div class="md:col-span-2 bg-gradient-to-br from-blue-600 via-blue-700 to-indigo-800 p-8 md:p-10 flex flex-col justify-center text-white">
              <span class={`inline-flex self-start items-center px-2.5 py-1 rounded-full text-xs font-semibold ${pillarMeta[featuredArticle.data.pillar]?.pillBg ?? 'bg-blue-100'} ${pillarMeta[featuredArticle.data.pillar]?.pillText ?? 'text-blue-800'} mb-4`}>
                {pillarMeta[featuredArticle.data.pillar]?.label ?? featuredArticle.data.pillar.toUpperCase()}
              </span>
              <p class="text-xs font-semibold uppercase tracking-widest text-blue-200 mb-2">
                Anchor article
              </p>
              <p class="text-sm text-blue-100 leading-relaxed">
                A comprehensive country-by-country reference covering 80+ jurisdictions implementing UN GHS — the strongest entry point into the Compliance Hub.
              </p>
            </div>
            <div class="md:col-span-3 p-8 md:p-10">
              <h3 class="text-2xl sm:text-3xl font-bold text-slate-900 leading-tight tracking-tight mb-3 group-hover:text-blue-700 transition-colors">
                {featuredArticle.data.title}
              </h3>
              <p class="text-slate-600 leading-relaxed mb-5">
                {featuredArticle.data.description}
              </p>
              <div class="flex items-center justify-between flex-wrap gap-3">
                <time class="text-sm text-slate-500" datetime={featuredArticle.data.pubDate.toISOString()}>
                  {formatDate(featuredArticle.data.pubDate)}
                </time>
                <span class="inline-flex items-center text-sm font-semibold text-blue-700 group-hover:translate-x-1 transition-transform">
                  Read article
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </span>
              </div>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- ============================================================ -->
  <!-- RECENT ARTICLES -->
  <!-- ============================================================ -->
  {recentArticles.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
      <div class="mb-10 flex items-end justify-between flex-wrap gap-4">
        <div>
          <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight mb-2">
            Recent Articles
          </h2>
          <p class="text-slate-600">
            Latest publications across all regulatory pillars.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {recentArticles.map((article) => {
          const meta = pillarMeta[article.data.pillar];
          return (
            <a
              href={`/compliance/${article.data.pillar}/${article.data.slug}/`}
              class="group block bg-white rounded-xl border border-slate-200 hover:border-blue-400 p-6 transition-all duration-200 hover:shadow-md hover:-translate-y-0.5"
            >
              <span class={`inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold ${meta?.pillBg ?? 'bg-slate-100'} ${meta?.pillText ?? 'text-slate-700'} mb-3`}>
                {meta?.label ?? article.data.pillar.toUpperCase()}
              </span>
              <h3 class="text-lg font-bold text-slate-900 leading-snug tracking-tight mb-2 group-hover:text-blue-700 transition-colors">
                {article.data.title}
              </h3>
              <p class="text-sm text-slate-600 leading-relaxed mb-4 line-clamp-3">
                {article.data.description}
              </p>
              <div class="flex items-center justify-between text-xs text-slate-500 pt-3 border-t border-slate-100">
                <time datetime={article.data.pubDate.toISOString()}>
                  {formatDate(article.data.pubDate)}
                </time>
                <span class="inline-flex items-center font-semibold text-blue-600 group-hover:translate-x-0.5 transition-transform">
                  Read
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <!-- ============================================================ -->
  <!-- BOTTOM CTA -->
  <!-- ============================================================ -->
  <section class="bg-slate-900 text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-3">
        Need a quick reference instead?
      </h2>
      <p class="text-slate-300 mb-6 max-w-2xl mx-auto">
        Jump straight to our pictogram library, ATE calculator, or substance database — fast lookups for working through real classification problems.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a href="/pictograms/" class="inline-flex items-center px-5 py-2.5 rounded-lg bg-white text-slate-900 font-semibold hover:bg-blue-50 transition-colors">
          Substance Database
        </a>
        <a href="/inspector/" class="inline-flex items-center px-5 py-2.5 rounded-lg bg-blue-600 text-white font-semibold hover:bg-blue-500 transition-colors">
          GHS vs ADR Inspector
        </a>
        <a href="/label-constructor/" class="inline-flex items-center px-5 py-2.5 rounded-lg border-2 border-white/30 text-white font-semibold hover:bg-white/10 transition-colors">
          Build a Label →
        </a>
      </div>
    </div>
  </section>
</Layout>
